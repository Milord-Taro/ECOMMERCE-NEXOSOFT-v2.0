@using ECOMMERCE_NEXOSOFT.Models

@{
    ViewData["Title"] = "Panel administrador";

    var stockCritico = ViewBag.StockCritico as List<Stock> ?? new List<Stock>();
    var ultimosPedidos = ViewBag.UltimosPedidos as List<Pedido> ?? new List<Pedido>();
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Panel administrador</h2>
        <p class="text-muted mb-0">Resumen general del sistema y accesos rápidos.</p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Productos</h6>
                    <h3 class="fw-bold">@ViewBag.TotalProductos</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Publicados</h6>
                    <h3 class="fw-bold text-success">@ViewBag.ProductosPublicados</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Stock bajo</h6>
                    <h3 class="fw-bold text-warning">@ViewBag.TotalStockBajo</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Pedidos</h6>
                    <h3 class="fw-bold">@ViewBag.TotalPedidos</h3>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Clientes</h6>
                    <h3 class="fw-bold">@ViewBag.TotalClientes</h3>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Vendedores</h6>
                    <h3 class="fw-bold">@ViewBag.TotalVendedores</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Resumen administrativo</h5>
                    <p class="text-muted mb-3">
                        Desde este panel puedes revisar solicitudes de vendedores, el estado general del marketplace y el comportamiento de los pedidos.
                    </p>

                    <div class="d-flex flex-wrap gap-2">
                        <a asp-controller="AdminSolicitudes" asp-action="Index" class="btn btn-outline-dark">Gestionar solicitudes</a>
                        <a href="#" class="btn btn-outline-dark">Ver estadísticas</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Últimos pedidos</h5>

                    @if (!ultimosPedidos.Any())
                    {
                        <p class="text-muted mb-0">No hay pedidos registrados.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Código</th>
                                        <th>Fecha</th>
                                        <th>Total</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pedido in ultimosPedidos)
                                    {
                                        <tr>
                                            <td>@pedido.CodPedido</td>
                                            <td>@pedido.FechaCreacion.ToString("dd/MM/yyyy")</td>
                                            <td>@pedido.Total.ToString("C")</td>
                                            <td>@pedido.EstadoPedido</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3">Accesos rápidos</h5>

            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="AdminSolicitudes" asp-action="Index" class="btn btn-outline-dark">Gestionar solicitudes</a>
                <a asp-controller="Home" asp-action="Categorias" class="btn btn-outline-dark">Ver catálogo público</a>
                <a asp-controller="Categoria" asp-action="Index" class="btn btn-outline-dark">Categorías</a>
                <a asp-controller="Subcategoria" asp-action="Index" class="btn btn-outline-dark">Subcategorías</a>
                <a asp-controller="AdminPedidos" asp-action="Index" class="btn btn-outline-dark">Ver pedidos marketplace</a>
                <a href="#" class="btn btn-outline-dark">Ver estadísticas</a>
            </div>
        </div>
    </div>
</div>