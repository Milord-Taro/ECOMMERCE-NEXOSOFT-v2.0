@using ECOMMERCE_NEXOSOFT.Models

@{
    ViewData["Title"] = "Panel administrador";

    var stockCritico = ViewBag.StockCritico as List<Stock> ?? new List<Stock>();
    var ultimosPedidos = ViewBag.UltimosPedidos as List<Pedido> ?? new List<Pedido>();
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Panel administrador</h2>
        <p class="text-muted mb-0">Resumen general del sistema y accesos rápidos.</p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Productos</h6>
                    <h3 class="fw-bold">@ViewBag.TotalProductos</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Publicados</h6>
                    <h3 class="fw-bold text-success">@ViewBag.ProductosPublicados</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Stock bajo</h6>
                    <h3 class="fw-bold text-warning">@ViewBag.TotalStockBajo</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Pedidos</h6>
                    <h3 class="fw-bold">@ViewBag.TotalPedidos</h3>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Clientes</h6>
                    <h3 class="fw-bold">@ViewBag.TotalClientes</h3>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Vendedores</h6>
                    <h3 class="fw-bold">@ViewBag.TotalVendedores</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Productos con stock crítico</h5>

                    @if (!stockCritico.Any())
                    {
                        <p class="text-muted mb-0">No hay alertas de stock.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Producto</th>
                                        <th>Actual</th>
                                        <th>Mínimo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in stockCritico)
                                    {
                                        bool stockBajo = item.StockActual <= item.StockMinimo;

                                        <tr class="@(stockBajo ? "table-warning" : "")">
                                            <td>@item.IdProductoNavigation?.NombreProducto</td>
                                            <td>@item.StockActual</td>
                                            <td>@item.StockMinimo</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Últimos pedidos</h5>

                    @if (!ultimosPedidos.Any())
                    {
                        <p class="text-muted mb-0">No hay pedidos registrados.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Código</th>
                                        <th>Fecha</th>
                                        <th>Total</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pedido in ultimosPedidos)
                                    {
                                        <tr>
                                            <td>@pedido.CodPedido</td>
                                            <td>@pedido.FechaCreacion.ToString("dd/MM/yyyy")</td>
                                            <td>@pedido.Total.ToString("C")</td>
                                            <td>@pedido.EstadoPedido</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3">Accesos rápidos</h5>

            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Producto" asp-action="Index" class="btn btn-dark">Administrar productos</a>
                <a asp-controller="Stock" asp-action="Index" class="btn btn-outline-dark">Administrar stock</a>
                <a asp-controller="MisPedidos" asp-action="Index" class="btn btn-outline-secondary">Ver pedidos</a>
            </div>
        </div>
    </div>
</div>