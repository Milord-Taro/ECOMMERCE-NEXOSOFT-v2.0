@model ECOMMERCE_NEXOSOFT.Models.Pedido

@{
    ViewData["Title"] = "Detalle del pedido";
}

<section class="container py-5">
    <h2 class="section-title mb-4">Detalle del pedido</h2>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <p class="mb-2"><strong>ID Pedido:</strong> @Model.IdPedido</p>
                    <p class="mb-2"><strong>Código:</strong> @Model.CodPedido</p>
                    <p class="mb-0"><strong>Fecha:</strong> @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</p>
                </div>

                <div class="col-md-4">
                    <p class="mb-2"><strong>Estado:</strong> @Model.EstadoPedido</p>
                    <p class="mb-2"><strong>Total:</strong> $@Model.Total.ToString("N2")</p>
                    <p class="mb-0"><strong>Método entrega:</strong> @(string.IsNullOrWhiteSpace(Model.MetodoEntrega) ? "No definido" : Model.MetodoEntrega)</p>
                </div>

                <div class="col-md-4">
                    <p class="mb-2"><strong>Cliente:</strong> @Model.IdUsuarioNavigation.Nombre @Model.IdUsuarioNavigation.Apellido</p>
                    <p class="mb-2"><strong>Correo:</strong> @Model.IdUsuarioNavigation.CorreoElectronico</p>
                    <p class="mb-0"><strong>Tienda:</strong> @(Model.IdTiendaNavigation?.NombreTienda ?? "Sin tienda")</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body">
            <h5 class="mb-3">Productos del pedido</h5>

            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Precio unitario</th>
                            <th>Cantidad</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Detallepedidos)
                        {
                            <tr>
                                <td>@item.IdProductoNavigation.NombreProducto</td>
                                <td>$@item.PrecioUnitario.ToString("N2")</td>
                                <td>@item.Cantidad</td>
                                <td>$@item.Subtotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <a asp-controller="AdminPedidos"
           asp-action="Index"
           class="btn btn-outline-secondary">
            Volver a pedidos
        </a>
    </div>
</section>