@model ECOMMERCE_NEXOSOFT.Models.SolicitudVendedor

@{
    ViewData["Title"] = "Aprobar solicitud";
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Aprobar solicitud</h2>
        <p class="text-muted mb-0">Se creará el vendedor y la tienda asociada automáticamente.</p>
    </div>

    <div class="mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary">← Volver a solicitudes</a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <dl class="row mb-4">
                <dt class="col-sm-3">Usuario</dt>
                <dd class="col-sm-9">@Model.IdUsuarioNavigation?.Nombre @Model.IdUsuarioNavigation?.Apellido</dd>

                <dt class="col-sm-3">Correo</dt>
                <dd class="col-sm-9">@Model.IdUsuarioNavigation?.CorreoElectronico</dd>

                <dt class="col-sm-3">Tienda solicitada</dt>
                <dd class="col-sm-9">@Model.NombreTiendaSolicitada</dd>

                <dt class="col-sm-3">Descripción</dt>
                <dd class="col-sm-9">@Model.DescripcionTienda</dd>
            </dl>

            <form asp-action="Aprobar">
                <input type="hidden" asp-for="IdSolicitudVendedor" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-dark">Confirmar aprobación</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>