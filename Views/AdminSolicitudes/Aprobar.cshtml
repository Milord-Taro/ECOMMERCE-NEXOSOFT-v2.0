@model ECOMMERCE_NEXOSOFT.Models.SolicitudVendedor

@{
    ViewData["Title"] = "Aprobar solicitud";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1">Aprobar solicitud</h2>
            <p class="text-muted mb-0">Confirma la aprobación de la solicitud y la creación de la tienda.</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            ← Volver a solicitudes
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3">Resumen</h5>

            <div class="row g-3">
                <div class="col-md-6">
                    <p class="mb-2"><strong>Usuario:</strong> @Model.IdUsuarioNavigation?.Nombre @Model.IdUsuarioNavigation?.Apellido</p>
                    <p class="mb-2"><strong>Correo:</strong> @Model.IdUsuarioNavigation?.CorreoElectronico</p>
                    <p class="mb-2"><strong>Tienda:</strong> @Model.NombreTiendaSolicitada</p>
                    <p class="mb-0"><strong>Razón social:</strong> @(string.IsNullOrWhiteSpace(Model.RazonSocial) ? "No registrada" : Model.RazonSocial)</p>
                </div>

                <div class="col-md-6">
                    <p class="mb-2"><strong>NIT/RUT:</strong> @(string.IsNullOrWhiteSpace(Model.NitRut) ? "No registrado" : Model.NitRut)</p>
                    <p class="mb-2"><strong>Representante:</strong> @(string.IsNullOrWhiteSpace(Model.NombreRepresentante) ? "No registrado" : Model.NombreRepresentante)</p>
                    <p class="mb-2"><strong>Contacto:</strong> @(string.IsNullOrWhiteSpace(Model.TelefonoContacto) ? "No registrado" : Model.TelefonoContacto)</p>
                    <p class="mb-0"><strong>Dirección:</strong> @(string.IsNullOrWhiteSpace(Model.DireccionComercial) ? "No registrada" : Model.DireccionComercial)</p>
                </div>
            </div>
        </div>
    </div>

    <form asp-action="Aprobar" method="post">
        <input type="hidden" asp-for="IdSolicitudVendedor" />
        @Html.AntiForgeryToken()

        <div class="alert alert-warning">
            Esta acción convertirá al usuario en vendedor, creará la tienda y lo registrará como miembro fundador con rol <strong>admin_tienda</strong>.
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button type="submit" class="btn btn-dark">Confirmar aprobación</button>
            <a asp-action="Details" asp-route-id="@Model.IdSolicitudVendedor" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>