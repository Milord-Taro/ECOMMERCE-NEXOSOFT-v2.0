@model IEnumerable<ECOMMERCE_NEXOSOFT.Models.SolicitudVendedor>

@{
    ViewData["Title"] = "Solicitudes de vendedor";
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Solicitudes de vendedor</h2>
        <p class="text-muted mb-0">Revisa, aprueba o rechaza solicitudes del marketplace.</p>
    </div>

    <div class="mb-3">
        <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">Volver a Dashboard</a>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success">@TempData["MensajeExito"]</div>
    }

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger">@TempData["MensajeError"]</div>
    }

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Código</th>
                            <th>Usuario</th>
                            <th>Tienda solicitada</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.CodSolicitudVendedor</td>
                                <td>@item.IdUsuarioNavigation?.Nombre (@item.IdUsuarioNavigation?.CorreoElectronico)</td>
                                <td>@item.NombreTiendaSolicitada</td>
                                <td>
                                    @if (item.EstadoSolicitud == "pendiente")
                                    {
                                        <span class="badge bg-warning text-dark">Pendiente</span>
                                    }
                                    else if (item.EstadoSolicitud == "aprobada")
                                    {
                                        <span class="badge bg-success">Aprobada</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Rechazada</span>
                                    }
                                </td>
                                <td>@item.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end flex-wrap gap-2">
                                        <a asp-action="Details" asp-route-id="@item.IdSolicitudVendedor" class="btn btn-sm btn-outline-secondary">Detalle</a>

                                        @if (item.EstadoSolicitud == "pendiente")
                                        {
                                            <a asp-action="Aprobar" asp-route-id="@item.IdSolicitudVendedor" class="btn btn-sm btn-dark">Aprobar</a>
                                            <a asp-action="Rechazar" asp-route-id="@item.IdSolicitudVendedor" class="btn btn-sm btn-danger">Rechazar</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>