@model ECOMMERCE_NEXOSOFT.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Recuperar contraseña";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold mb-2">Recuperar contraseña</h2>
                        <p class="text-muted mb-0">Ingresa tu correo para continuar.</p>
                    </div>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                        <div class="mb-3">
                            <label asp-for="CorreoElectronico" class="form-label fw-semibold">Correo electrónico</label>
                            <input asp-for="CorreoElectronico" class="form-control" placeholder="ejemplo@correo.com" />
                            <span asp-validation-for="CorreoElectronico" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-dark w-100 py-2 fw-semibold rounded-3">
                            Continuar
                        </button>
                    </form>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger mt-3 text-center">
                            @ViewBag.Error
                        </div>
                    }

                    <div class="text-center mt-4">
                        <a asp-controller="Auth" asp-action="Login" class="fw-semibold text-decoration-none">
                            Volver al inicio de sesión
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}