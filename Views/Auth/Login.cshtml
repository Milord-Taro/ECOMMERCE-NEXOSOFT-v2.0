@model ECOMMERCE_NEXOSOFT.ViewModels.LoginViewModel

<div class="login-wrapper">
    <div class="login-card">

        <h3 class="text-center mb-4">Iniciar Sesión</h3>

        <form method="post">

            <div class="mb-3">
                <label class="form-label">Correo</label>
                <input asp-for="CorreoElectronico" class="form-control" placeholder="ejemplo@email.com" />
            </div>

            <div class="mb-3">
                <label class="form-label">Contraseña</label>

                <div class="password-wrapper">
                    <input asp-for="Contrasena"
                           class="form-control pe-5"
                           id="LoginContrasena" />
                    <button type="button"
                            class="password-toggle"
                            onclick="togglePassword('LoginContrasena', this)">
                        👁
                    </button>
                </div>

                <span asp-validation-for="Contrasena" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-login">
                Ingresar
            </button>

        </form>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger mt-3 text-center">
                @ViewBag.Error
            </div>
        }


        <div class="text-center mt-3">
            <span>¿No tienes cuenta?</span>
            <a asp-controller="Auth" asp-action="Register" class="link-register">
                Regístrate
            </a>
        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function togglePassword(inputId, button) {
            const input = document.getElementById(inputId);

            if (input.type === "password") {
                input.type = "text";
                button.innerHTML = "🙈";
            } else {
                input.type = "password";
                button.innerHTML = "👁";
            }
        }
    </script>
}