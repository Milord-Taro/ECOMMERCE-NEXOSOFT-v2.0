@model ECOMMERCE_NEXOSOFT.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Registrarse";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-7 p-md-6">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold mb-1">Crear cuenta</h2>
                        <p class="text-muted mb-0">Registra tus datos para acceder a la plataforma.</p>
                    </div>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    <form asp-action="Register" method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Nombre" class="form-label fw-semibold">Nombre</label>
                                <input asp-for="Nombre" class="form-control js-name-50" />
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Apellido" class="form-label fw-semibold">Apellido</label>
                                <input asp-for="Apellido" class="form-control js-name-50" />
                                <span asp-validation-for="Apellido" class="text-danger"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="TipoIdentificacion" class="form-label fw-semibold">Tipo de identificación</label>
                                <select asp-for="TipoIdentificacion" class="form-select">
                                    <option value="">Selecciona una opción</option>
                                    <option value="cc">Cédula</option>
                                    <option value="ti">Tarjeta de identidad</option>
                                    <option value="ppt">PPT</option>
                                    <option value="pasaporte">Pasaporte</option>
                                </select>
                                <span asp-validation-for="TipoIdentificacion" class="text-danger"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="NumeroIdentificacion" class="form-label fw-semibold">Número de identificación</label>
                                <input asp-for="NumeroIdentificacion" class="form-control js-id-10" />
                                <span asp-validation-for="NumeroIdentificacion" class="text-danger"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Telefono" class="form-label fw-semibold">Teléfono</label>
                                <input asp-for="Telefono" class="form-control js-phone-10" />
                                <span asp-validation-for="Telefono" class="text-danger"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="CorreoElectronico" class="form-label fw-semibold">Correo electrónico</label>
                                <input asp-for="CorreoElectronico" class="form-control js-email-100" />
                                <span asp-validation-for="CorreoElectronico" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Contrasena" class="form-label fw-semibold">Contraseña</label>
                                <input asp-for="Contrasena" type="password" class="form-control js-password-100" />
                                <span asp-validation-for="Contrasena" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ConfirmarContrasena" class="form-label fw-semibold">Confirmar contraseña</label>
                                <input asp-for="ConfirmarContrasena" type="password" class="form-control js-password-100" />
                                <span asp-validation-for="ConfirmarContrasena" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="alert alert-info mt-4 mb-0">
                            La contraseña debe tener mínimo 8 caracteres, incluir mayúscula, minúscula, número y carácter especial.
                        </div>

                        <div class="d-flex gap-2 mt-4 flex-wrap">
                            <button type="submit" class="btn btn-dark">Registrarme</button>
                            <a asp-action="Login" class="btn btn-outline-secondary">Ya tengo cuenta</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}