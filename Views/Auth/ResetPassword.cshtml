@model ECOMMERCE_NEXOSOFT.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Nueva contraseña";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold mb-2">Nueva contraseña</h2>
                        <p class="text-muted mb-0">Actualiza la contraseña de tu cuenta.</p>
                    </div>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                        <input type="hidden" asp-for="CorreoElectronico" />

                        <div class="mb-3">
                            <label asp-for="NuevaContrasena" class="form-label fw-semibold">Nueva contraseña</label>
                            <div class="password-wrapper">
                                <input asp-for="NuevaContrasena" class="form-control pe-5" id="NuevaContrasena" />
                                <button type="button" class="password-toggle" onclick="togglePassword('NuevaContrasena', this)">👁</button>
                            </div>
                            <span asp-validation-for="NuevaContrasena" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmarContrasena" class="form-label fw-semibold">Confirmar contraseña</label>
                            <div class="password-wrapper">
                                <input asp-for="ConfirmarContrasena" class="form-control pe-5" id="ConfirmarNuevaContrasena" />
                                <button type="button" class="password-toggle" onclick="togglePassword('ConfirmarNuevaContrasena', this)">👁</button>
                            </div>
                            <span asp-validation-for="ConfirmarContrasena" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-dark w-100 py-2 fw-semibold rounded-3">
                            Guardar nueva contraseña
                        </button>
                    </form>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger mt-3 text-center">
                            @ViewBag.Error
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function togglePassword(inputId, button) {
            const input = document.getElementById(inputId);

            if (input.type === "password") {
                input.type = "text";
                button.innerHTML = "🙈";
            } else {
                input.type = "password";
                button.innerHTML = "👁";
            }
        }
    </script>
}