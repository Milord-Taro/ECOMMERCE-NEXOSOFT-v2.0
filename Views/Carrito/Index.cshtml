@model List<ECOMMERCE_NEXOSOFT.Models.CarritoItem>

@{
    ViewData["Title"] = "Carrito";
    decimal total = Model.Sum(x => x.Precio * x.Cantidad);
}

<section class="container py-5">
    <h2 class="section-title mb-4">Carrito de compras</h2>

    @if (TempData["MensajeCarrito"] != null)
    {
        <div class="alert alert-warning">
            @TempData["MensajeCarrito"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Tu carrito está vacío.
        </div>

        <a asp-controller="Productos" asp-action="Index" class="btn btn-danger">
            Ir al catálogo
        </a>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Precio</th>
                        <th>Cantidad</th>
                        <th>Subtotal</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.NombreProducto</td>
                            <td>$@item.Precio.ToString("N2")</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <a asp-controller="Carrito"
                                       asp-action="Disminuir"
                                       asp-route-id="@item.IdProducto"
                                       class="btn btn-sm btn-outline-secondary">
                                        -
                                    </a>

                                    <span>@item.Cantidad</span>

                                    <a asp-controller="Carrito"
                                       asp-action="Aumentar"
                                       asp-route-id="@item.IdProducto"
                                       class="btn btn-sm btn-outline-secondary">
                                        +
                                    </a>
                                </div>
                            </td>
                            <td>$@((item.Precio * item.Cantidad).ToString("N2"))</td>
                            <td>
                                <a asp-controller="Carrito"
                                   asp-action="Eliminar"
                                   asp-route-id="@item.IdProducto"
                                   class="btn btn-sm btn-outline-danger">
                                    Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mt-4">
            <div>
                <a asp-controller="Productos" asp-action="Index" class="btn btn-outline-secondary">
                    Seguir comprando
                </a>

                <a asp-controller="Carrito" asp-action="Vaciar" class="btn btn-outline-danger ms-2">
                    Vaciar carrito
                </a>

                <a asp-controller="Checkout" asp-action="Index" class="btn btn-danger ms-2">
                    Continuar compra
                </a>
            </div>

            <div class="text-md-end">
                <h4 class="mb-0">Total: $@total.ToString("N2")</h4>
            </div>
        </div>
    }
</section>