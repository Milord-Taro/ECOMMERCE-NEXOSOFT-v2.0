@model ECOMMERCE_NEXOSOFT.Models.Categorium
@using ECOMMERCE_NEXOSOFT.Helpers

@{
    ViewData["Title"] = "Nueva categoría";
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Nueva categoría</h2>
        <p class="text-muted mb-0">Registra una nueva categoría para el catálogo.</p>
    </div>

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger">@TempData["MensajeError"]</div>
    }

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="CodCategoria" class="form-label fw-semibold">Código</label>
                        <input asp-for="CodCategoria" class="@FormFieldCss.Code9" />
                        <span asp-validation-for="CodCategoria" class="text-danger"></span>
                    </div>

                    <div class="col-md-8">
                        <label asp-for="NombreCategoria" class="form-label fw-semibold">Nombre</label>
                        <input asp-for="NombreCategoria" class="@FormFieldCss.Text40" />
                        <span asp-validation-for="NombreCategoria" class="text-danger"></span>
                        <small class="text-muted">Entre 3 y 40 caracteres.</small>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Descripcion" class="form-label fw-semibold">Descripción</label>
                        <textarea asp-for="Descripcion" class="@FormFieldCss.Text100" rows="4"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                        <small class="text-muted">Entre 3 y 100 caracteres.</small>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-dark">Guardar categoría</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}