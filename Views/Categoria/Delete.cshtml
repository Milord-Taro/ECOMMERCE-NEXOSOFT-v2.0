@model ECOMMERCE_NEXOSOFT.Models.Categorium

@{
    ViewData["Title"] = "Ocultar categoría";
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Ocultar categoría</h2>
        <p class="text-muted mb-0">Esta categoría dejará de mostrarse públicamente, pero seguirá guardada en el sistema.</p>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <dl class="row mb-4">
                <dt class="col-sm-3">Código</dt>
                <dd class="col-sm-9">@Model.CodCategoria</dd>

                <dt class="col-sm-3">Nombre</dt>
                <dd class="col-sm-9">@Model.NombreCategoria</dd>

                <dt class="col-sm-3">Descripción</dt>
                <dd class="col-sm-9">@Model.Descripcion</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="IdCategoria" />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Confirmar ocultar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>