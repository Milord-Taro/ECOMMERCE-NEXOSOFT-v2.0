@model ECOMMERCE_NEXOSOFT.Models.Categorium

@{
    ViewData["Title"] = "Editar categoría";
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Editar categoría</h2>
        <p class="text-muted mb-0">Actualiza la información de la categoría seleccionada.</p>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="IdCategoria" />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="CodCategoria" class="form-label fw-semibold">Código</label>
                        <input asp-for="CodCategoria" class="form-control" />
                        <span asp-validation-for="CodCategoria" class="text-danger"></span>
                    </div>

                    <div class="col-md-8">
                        <label asp-for="NombreCategoria" class="form-label fw-semibold">Nombre</label>
                        <input asp-for="NombreCategoria" class="form-control" />
                        <span asp-validation-for="NombreCategoria" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Descripcion" class="form-label fw-semibold">Descripción</label>
                        <textarea asp-for="Descripcion" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-check mt-2">
                        <input class="form-check-input" asp-for="VisiblePublico" />
                        <label class="form-check-label fw-semibold" asp-for="VisiblePublico">
                            Visible públicamente
                        </label>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-dark">Guardar cambios</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}