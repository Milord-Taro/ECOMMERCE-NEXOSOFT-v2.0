@model IEnumerable<ECOMMERCE_NEXOSOFT.Models.Categorium>

@{
    ViewData["Title"] = "Categorías";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1">Categorías</h2>
            <p class="text-muted mb-0">Administra las categorías del catálogo.</p>
        </div>

        <div class="mb-3">
            <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">Volver a Dashboard</a>
        </div>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success">
            @TempData["MensajeExito"]
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body p-4">
            <form method="get" class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Buscar</label>
                    <input type="text"
                           name="buscar"
                           value="@ViewBag.Buscar"
                           class="form-control"
                           placeholder="Código o nombre de categoría" />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Visibilidad</label>
                    <select name="visible" class="form-select">
                        <option value="">Todas</option>
                        @if (ViewBag.Visible != null && ViewBag.Visible == true)
                        {
                            <option value="true" selected>Visibles</option>
                        }
                        else
                        {
                            <option value="true">Visibles</option>
                        }

                        @if (ViewBag.Visible != null && ViewBag.Visible == false)
                        {
                            <option value="false" selected>Ocultas</option>
                        }
                        else
                        {
                            <option value="false">Ocultas</option>
                        }
                    </select>
                </div>

                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-dark w-100">Buscar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">Limpiar</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Código</th>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Visible</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.CodCategoria</td>
                                <td>@item.NombreCategoria</td>
                                <td>@item.Descripcion</td>
                                <td>
                                    @if (item.VisiblePublico)
                                    {
                                        <span class="badge bg-success">Visible</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Oculta</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end flex-wrap gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.IdCategoria" class="btn btn-sm btn-outline-dark">Editar</a>
                                        <a asp-action="Details" asp-route-id="@item.IdCategoria" class="btn btn-sm btn-outline-secondary">Detalle</a>
                                    </div>
                                </td>
                            </tr>
                        }

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">
                                    No se encontraron categorías.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-4 mt-4">
        <a asp-action="Create" class="btn btn-dark">Nueva categoría</a>
        <a asp-controller="Subcategoria" asp-action="Index" class="btn btn-outline-dark">Ir a subcategorías</a>
    </div>
</div>