@model List<ECOMMERCE_NEXOSOFT.Models.CarritoItem>
@using System.Linq

@{
    ViewData["Title"] = "Checkout";
    decimal total = Model.Sum(x => x.Precio * x.Cantidad);
    var direccionesEntrega = ViewBag.DireccionesEntrega as List<string> ?? new List<string>();
    var telefonoEntrega = ViewBag.TelefonoEntrega as string ?? string.Empty;
    var checkoutBloqueado = !direccionesEntrega.Any() || string.IsNullOrWhiteSpace(telefonoEntrega);

    var gruposPorTienda = Model
        .GroupBy(x => new { x.IdTienda, x.NombreTienda })
        .ToList();
}

<section class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="section-title mb-1">Finalizar compra</h2>
            <p class="text-muted mb-0">Confirma la entrega y selecciona tu método de pago.</p>
        </div>

        <a asp-controller="Carrito" asp-action="Index" class="btn btn-outline-secondary">
            ← Volver al carrito
        </a>
    </div>

    @if (TempData["MensajeCheckout"] != null)
    {
        <div class="alert alert-warning rounded-4">
            @TempData["MensajeCheckout"]
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-8">
            <form id="checkoutForm" asp-controller="Checkout" asp-action="Confirmar" method="post">
                @Html.AntiForgeryToken()

                <div class="card shadow-sm border-0 rounded-4 mb-4">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                            <div>
                                <h5 class="fw-bold mb-1">Dirección de entrega</h5>
                                <p class="text-muted mb-0">Selecciona una dirección registrada en tu perfil.</p>
                            </div>

                            <a asp-controller="Perfil" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                                Cambiar
                            </a>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Dirección</label>
                                <select name="direccionEntrega" class="form-select" required @(checkoutBloqueado ? "disabled" : null)>
                                    <option value="">Selecciona una dirección</option>
                                    @foreach (var direccion in direccionesEntrega)
                                    {
                                        <option value="@direccion">@direccion</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0 rounded-4 mb-4">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                            <div>
                                <h5 class="fw-bold mb-1">Información de contacto</h5>
                                <p class="text-muted mb-0">Este teléfono se usará para coordinar la entrega.</p>
                            </div>

                            <a asp-controller="Perfil" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                                Cambiar
                            </a>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Teléfono de contacto</label>
                                <input type="text"
                                       name="telefonoEntrega"
                                       class="form-control"
                                       value="@telefonoEntrega"
                                       readonly />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0 rounded-4 mb-4">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                            <div>
                                <h5 class="fw-bold mb-1">Método de pago</h5>
                                <p class="text-muted mb-0">Elige cómo deseas pagar tu compra.</p>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Selecciona una opción</label>
                                <select name="metodoPago" class="form-select" required @(checkoutBloqueado ? "disabled" : null)>
                                    <option value="">Selecciona una opción</option>
                                    <option value="tarjeta debito">Tarjeta débito</option>
                                    <option value="tarjeta credito">Tarjeta crédito</option>
                                    <option value="transferencias">Transferencia</option>
                                    <option value="efectivo">Contra entrega / efectivo</option>
                                </select>
                                <small class="text-muted">
                                    Tarjetas y transferencia te llevarán a una pasarela demo. Efectivo confirma directamente.
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">Productos de tu compra</h5>

                        @foreach (var grupo in gruposPorTienda)
                        {
                            <div class="border rounded-4 p-3 mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                                    <div>
                                        <h6 class="fw-bold mb-1">
                                            @(string.IsNullOrWhiteSpace(grupo.Key.NombreTienda)
                                                                                    ? "Tienda no identificada"
                                                                                    : grupo.Key.NombreTienda)
                                        </h6>
                                        <p class="text-muted mb-0">@grupo.Count() producto(s)</p>
                                    </div>
                                </div>

                            @foreach (var item in grupo)
                                {
                                    <div class="row align-items-center g-3 mb-3">
                                        <div class="col-md-2 col-4">
                                            <img src="@(string.IsNullOrWhiteSpace(item.ImagenUrl) ? "/img/producto-default.jpg" : item.ImagenUrl)"
                                                 alt="@item.NombreProducto"
                                                 class="img-fluid rounded-3 border"
                                                 style="width: 100%; max-height: 100px; object-fit: cover;" />
                                        </div>

                                        <div class="col-md-5 col-8">
                                            <h6 class="fw-semibold mb-1">@item.NombreProducto</h6>
                                            <p class="text-muted mb-0">Cantidad: @item.Cantidad</p>
                                        </div>

                                        <div class="col-md-2 col-6">
                                            <span class="text-muted d-block small">Precio</span>
                                            <strong>$@item.Precio.ToString("N2")</strong>
                                        </div>

                                        <div class="col-md-3 col-6 text-md-end">
                                            <span class="text-muted d-block small">Subtotal</span>
                                            <strong>$@((item.Precio * item.Cantidad).ToString("N2"))</strong>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </form>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 position-sticky" style="top: 100px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Resumen del pedido</h5>

                    <div class="d-flex justify-content-between mb-2">
                        <span>Productos</span>
                        <strong>@Model.Sum(x => x.Cantidad)</strong>
                    </div>

                    <div class="d-flex justify-content-between mb-3">
                        <span>Envío</span>
                        <strong>$0.00</strong>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="fw-semibold">Total a pagar</span>
                        <h4 class="mb-0">$@total.ToString("N2")</h4>
                    </div>

                    @if (checkoutBloqueado)
                    {
                        <div class="alert alert-danger mb-3">
                            Debes tener al menos una dirección y un teléfono registrados antes de confirmar el pedido.
                        </div>

                        <div class="d-grid">
                            <a asp-controller="Perfil" asp-action="Index" class="btn btn-dark">
                                Completar perfil
                            </a>
                        </div>
                    }
                    else
                    {
                        <button type="submit"
                                form="checkoutForm"
                                class="btn btn-danger w-100">
                            Continuar al pago
                        </button>
                    }

                    <p class="text-muted small mt-3 mb-0">
                        Revisa tu dirección, método de pago y productos antes de continuar.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>