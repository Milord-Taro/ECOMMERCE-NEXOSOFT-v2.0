@model List<ECOMMERCE_NEXOSOFT.Models.CarritoItem>

@{
    ViewData["Title"] = "Checkout";
    decimal total = Model.Sum(x => x.Precio * x.Cantidad);
}

@if (TempData["MensajeCheckout"] != null)
{
    <div class="alert alert-warning">
        @TempData["MensajeCheckout"]
    </div>
}

<section class="container py-5">
    <h2 class="section-title mb-4">Resumen de compra</h2>
    <div class="table-responsive mb-4">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Precio</th>
                    <th>Cantidad</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.NombreProducto</td>
                        <td>$@item.Precio.ToString("N2")</td>
                        <td>@item.Cantidad</td>
                        <td>$@((item.Precio * item.Cantidad).ToString("N2"))</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center">
        <div class="text-end">
            <h4>Total: $@total.ToString("N2")</h4>

            <form asp-controller="Checkout" asp-action="Confirmar" method="post" class="mt-3">
                @if (TempData["MensajeCheckout"] != null)
                {
                    <div class="alert alert-danger mb-3">
                        @TempData["MensajeCheckout"]
                    </div>
                }

                <div class="card shadow-sm border-0 rounded-4 mb-4">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                            <div>
                                <h5 class="fw-bold mb-1">Dirección de entrega</h5>
                                <p class="text-muted mb-0">Confirma la información antes de finalizar tu compra.</p>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-8">
                                <label class="form-label fw-semibold">Dirección</label>
                                <input type="text"
                                       name="direccionEntrega"
                                       class="form-control"
                                       value="@ViewBag.DireccionEntrega"
                                       placeholder="Ej: Calle 123 #45-67, Bogotá"
                                       required />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Teléfono de contacto</label>
                                <input type="text"
                                       name="telefonoEntrega"
                                       class="form-control"
                                       value="@ViewBag.TelefonoEntrega"
                                       placeholder="Ej: 3001234567"
                                       required />
                            </div>
                        </div>
                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Método de pago</label>
                                <select name="metodoPago" class="form-select" required>
                                    <option value="">Selecciona una opción</option>
                                    <option value="tarjeta debito">Tarjeta débito</option>
                                    <option value="tarjeta credito">Tarjeta crédito</option>
                                    <option value="transferencias">Transferencia</option>
                                    <option value="efectivo">Contra entrega / efectivo</option>
                                </select>
                            </div>
                        </div>
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">
                            Confirmar pedido
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>