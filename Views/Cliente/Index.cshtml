@using ECOMMERCE_NEXOSOFT.Models

@{
    ViewData["Title"] = "Mi cuenta";
    var ultimosPedidos = ViewBag.UltimosPedidos as List<Pedido> ?? new List<Pedido>();
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Mi cuenta</h2>
        <p class="text-muted mb-0">Consulta tu actividad y accede a tus opciones principales.</p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Pedidos realizados</h6>
                    <h3 class="fw-bold">@ViewBag.TotalPedidos</h3>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted mb-3">Accesos rápidos</h6>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-controller="Perfil" asp-action="Index" class="btn btn-dark">Mi perfil</a>
                        <a asp-controller="MisPedidos" asp-action="Index" class="btn btn-outline-dark">Mis pedidos</a>
                        <a asp-controller="Productos" asp-action="Index" class="btn btn-outline-secondary">Seguir comprando</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body">
            <h5 class="fw-bold mb-3">Últimos pedidos</h5>

            @if (!ultimosPedidos.Any())
            {
                <p class="text-muted mb-0">Aún no tienes pedidos registrados.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Código</th>
                                <th>Fecha</th>
                                <th>Total</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pedido in ultimosPedidos)
                            {
                                <tr>
                                    <td>@pedido.CodPedido</td>
                                    <td>@pedido.FechaCreacion.ToString("dd/MM/yyyy")</td>
                                    <td>@pedido.Total.ToString("C")</td>
                                    <td>@pedido.EstadoPedido</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>