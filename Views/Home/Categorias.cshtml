@model IEnumerable<ECOMMERCE_NEXOSOFT.Models.Categorium>

@{
    ViewData["Title"] = "Categorías";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1">Explorar categorías</h2>
            <p class="text-muted mb-0">Encuentra productos por categoría.</p>
        </div>

        <a asp-controller="Productos" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4">
            Ver todos los productos
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light border rounded-4 shadow-sm">
            No hay categorías disponibles en este momento.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                    <div class="card h-100 border-0 shadow-sm rounded-4">
                        <div class="card-body d-flex flex-column p-4">
                            <div class="mb-3">
                                <div class="bg-light rounded-4 d-flex align-items-center justify-content-center"
                                     style="height: 180px;">
                                    <img src="~/img/producto-default.jpg"
                                         alt="@item.NombreCategoria"
                                         class="img-fluid"
                                         style="max-height: 140px;" />
                                </div>
                            </div>

                            <h5 class="fw-bold mb-2">@item.NombreCategoria</h5>

                            <p class="text-muted small mb-4" style="min-height: 48px;">
                                @(string.IsNullOrWhiteSpace(item.Descripcion)
                                                        ? "Explora productos relacionados con esta categoría."
                                                        : item.Descripcion)
                    </p>

                            <div class="mt-auto">
                                <a asp-controller="Productos"
                                   asp-action="Index"
                                   asp-route-categoria="@item.IdCategoria"
                                   class="btn btn-dark rounded-pill w-100">
                                    Explorar categoría
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                }
        </div>
    }
</div>