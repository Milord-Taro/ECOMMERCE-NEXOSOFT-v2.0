@{
    ViewData["Title"] = "Contacto";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold mb-2">Contáctanos</h2>
        <p class="text-muted mb-0">Estamos disponibles para resolver dudas y recibir solicitudes.</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Información de contacto</h5>
                    <p class="mb-2"><strong>Correo:</strong> ventas@nexosoft.com.co</p>
                    <p class="mb-2"><strong>Teléfono:</strong> +57 (601) 234 5678</p>
                    <p class="mb-0"><strong>Ciudad:</strong> Bogotá, Colombia</p>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Horario de atención</h5>
                    <p class="mb-2">Lunes a viernes: 8:00 AM - 6:00 PM</p>
                    <p class="mb-2">Sábados: 8:00 AM - 1:00 PM</p>
                    <p class="mb-0">Domingos y festivos: no disponible</p>
                </div>
            </div>
        </div>
    </div>
</div>