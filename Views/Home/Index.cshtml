@model ECOMMERCE_NEXOSOFT.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Inicio";
}

<section class="hero-section">
    <div class="container py-5">
        <div class="hero-banner position-relative overflow-hidden rounded-4">
            <img src="https://images.unsplash.com/photo-1649691594234-525b1bfe01f2?auto=format&fit=crop&w=1400&q=80"
                 alt="Banner principal"
                 class="hero-image" />

            <div class="hero-overlay"></div>

            <div class="hero-content position-absolute top-50 start-0 translate-middle-y text-white px-4 px-md-5">
                <div class="col-lg-7">
                    <h1 class="hero-title mb-3">
                        Innovación en <span class="text-danger">Ferretería</span>
                    </h1>
                    <p class="hero-text mb-4">
                        Las mejores herramientas y equipos profesionales para tus proyectos.
                        Calidad garantizada y tecnología de punta.
                    </p>
                    <div class="d-flex flex-column flex-sm-row gap-3">
                        <a href="#" class="btn btn-danger btn-lg px-4">Ver catálogo</a>
                        <a href="#" class="btn btn-outline-light btn-lg px-4">Ofertas especiales</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="benefits-section py-4">
    <div class="container">
        <div class="row g-4">
            <div class="col-12 col-md-6 col-lg-3">
                <div class="benefit-card text-center">
                    <h5>Envío Gratis</h5>
                    <p>En compras superiores a $150.000</p>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <div class="benefit-card text-center">
                    <h5>Garantía Extendida</h5>
                    <p>Hasta 2 años en productos seleccionados</p>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <div class="benefit-card text-center">
                    <h5>Pago Seguro</h5>
                    <p>Múltiples métodos de pago disponibles</p>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <div class="benefit-card text-center">
                    <h5>Soporte 24/7</h5>
                    <p>Asesoría técnica especializada</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="categories-section py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="section-title">Categorías destacadas</h2>
            <a asp-controller="Productos" asp-action="Index" class="section-link">Ver todas →</a>
        </div>

        <div class="row g-4">
            @foreach (var categoria in Model.Categorias)
            {
                <div class="col-6 col-md-4 col-lg-2">
                    <div class="category-card">
                        <img src="/img/categoria-default.jpg" alt="@categoria.NombreCategoria" />

                        <div class="category-info">
                            <h6>@categoria.NombreCategoria</h6>

                            <a asp-controller="Productos"
                               asp-action="Index"
                               asp-route-categoria="@categoria.IdCategoria"
                               class="section-link">
                                Explorar categoría
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="featured-products py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="section-title">Productos destacados</h2>
            <a href="#" class="section-link">Ver todos →</a>
        </div>

        <div class="row g-4">

            @foreach (var producto in Model.ProductosDestacados)
            {
                <div class="col-lg-3 col-md-4 col-6">

                    <div class="product-card">

                        <div class="product-image-wrap">

                            <img src="/img/producto-default.jpg" alt="@producto.NombreProducto">

                            @if (producto.Favorito)
                            {
                                <span class="product-badge">Destacado</span>
                            }

                        </div>

                        <div class="product-body">

                            <h6>@producto.NombreProducto</h6>

                            <div class="product-price">
                                <span class="price-current">
                                    $@producto.PrecioVentaProducto.ToString("N2")
                                </span>
                            </div>

                            <button class="btn btn-danger w-100">
                                Ver producto
                            </button>

                        </div>

                    </div>

                </div>
            }

        </div>
    </div>
</section>

<section class="promo-section py-5">
    <div class="container">
        <div class="promo-banner">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h2>¡Ofertas Especiales de Marzo!</h2>
                    <p>
                        Hasta 40% de descuento en herramientas eléctricas y accesorios.
                        Aprovecha nuestras promociones especiales este mes.
                    </p>
                    <a href="#" class="btn btn-light btn-lg">Ver ofertas</a>
                </div>
            </div>
        </div>
    </div>
</section>
