@{
    ViewData["Title"] = "Nosotros";
}

<div class="container py-5">
    <div class="row align-items-center g-5">
        <div class="col-lg-6">
            <h2 class="fw-bold mb-3">Sobre Nexosoft</h2>
            <p class="text-muted">
                Nexosoft es una plataforma ecommerce enfocada en productos de ferretería y hogar,
                pensada para facilitar la publicación, búsqueda y compra de productos en línea.
            </p>
            <p class="text-muted">
                El objetivo del proyecto es ofrecer una experiencia clara, moderna y funcional,
                con una base preparada para crecer hacia un marketplace multi-vendedor.
            </p>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">¿Qué ofrecemos?</h5>
                    <ul class="mb-0 text-muted">
                        <li>Catálogo de productos organizado</li>
                        <li>Filtros por categoría y subcategoría</li>
                        <li>Carrito de compras y gestión de pedidos</li>
                        <li>Experiencia pensada para clientes y vendedores</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>