@{
    ViewData["Title"] = "Ofertas";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold mb-2">Ofertas y promociones</h2>
        <p class="text-muted mb-0">Descubre oportunidades destacadas del catálogo.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    <h5 class="fw-bold mb-2">Promociones destacadas</h5>
                    <p class="text-muted">Aquí podrás publicar campañas, descuentos y productos recomendados.</p>
                    <a asp-controller="Productos" asp-action="Index" class="btn btn-dark rounded-pill px-4">
                        Ver productos
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    <h5 class="fw-bold mb-2">Combos y packs</h5>
                    <p class="text-muted">Espacio ideal para mostrar ofertas especiales de temporada.</p>
                    <a asp-controller="Productos" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4">
                        Explorar catálogo
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    <h5 class="fw-bold mb-2">Novedades</h5>
                    <p class="text-muted">Puedes usar esta sección para campañas visibles al cliente.</p>
                    <a asp-controller="Productos" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                        Seguir comprando
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>