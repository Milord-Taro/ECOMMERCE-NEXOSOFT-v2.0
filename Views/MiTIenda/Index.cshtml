@model ECOMMERCE_NEXOSOFT.Models.Tienda

@{
    ViewData["Title"] = "Mi tienda";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1">Mi tienda</h2>
            <p class="text-muted mb-0">Consulta la información general de tu tienda.</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Edit" class="btn btn-dark">Editar tienda</a>
            <a asp-controller="Vendedor" asp-action="Index" class="btn btn-outline-secondary">← Volver al panel</a>
        </div>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success">@TempData["MensajeExito"]</div>
    }

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger">@TempData["MensajeError"]</div>
    }

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-sm-3">Código</dt>
                <dd class="col-sm-9">@Model.CodTienda</dd>

                <dt class="col-sm-3">Nombre</dt>
                <dd class="col-sm-9">@Model.NombreTienda</dd>

                <dt class="col-sm-3">Descripción</dt>
                <dd class="col-sm-9">@Model.Descripcion</dd>

                <dt class="col-sm-3">Logo URL</dt>
                <dd class="col-sm-9">@Model.LogoUrl</dd>

                <dt class="col-sm-3">Visible</dt>
                <dd class="col-sm-9">
                    @if (Model.VisiblePublico)
                    {
                        <span class="badge bg-success">Visible</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Oculta</span>
                    }
                </dd>
            </dl>
        </div>
    </div>
</div>