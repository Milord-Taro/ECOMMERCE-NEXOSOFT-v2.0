@model ECOMMERCE_NEXOSOFT.ViewModels.MiembroTiendaEditViewModel

@{
    ViewData["Title"] = "Editar miembro interno";
    var nombreTienda = ViewBag.NombreTienda as string ?? "Mi tienda";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1">Editar miembro interno</h2>
            <p class="text-muted mb-0">Actualiza la información de la cuenta interna de la tienda.</p>
            <p class="mb-0 mt-2"><strong>Tienda:</strong> @nombreTienda</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            ← Volver a miembros
        </a>
    </div>

    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input asp-for="IdMiembroTienda" type="hidden" />
        <input asp-for="IdUsuario" type="hidden" />

        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Datos personales</h5>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Nombre" class="form-label fw-semibold">Nombre</label>
                        <input asp-for="Nombre" class="form-control js-name-50" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Apellido" class="form-label fw-semibold">Apellido</label>
                        <input asp-for="Apellido" class="form-control js-name-50" />
                        <span asp-validation-for="Apellido" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="TipoIdentificacion" class="form-label fw-semibold">Tipo identificación</label>
                        <select asp-for="TipoIdentificacion" class="form-select">
                            <option value="cc">Cédula</option>
                            <option value="ti">Tarjeta de identidad</option>
                            <option value="ppt">PPT</option>
                            <option value="pasaporte">Pasaporte</option>
                        </select>
                        <span asp-validation-for="TipoIdentificacion" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="NumeroIdentificacion" class="form-label fw-semibold">Número identificación</label>
                        <input asp-for="NumeroIdentificacion" class="form-control js-id-10" />
                        <span asp-validation-for="NumeroIdentificacion" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Telefono" class="form-label fw-semibold">Teléfono</label>
                        <input asp-for="Telefono" class="form-control js-phone-10" />
                        <span asp-validation-for="Telefono" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CorreoElectronico" class="form-label fw-semibold">Correo</label>
                        <input asp-for="CorreoElectronico" class="form-control js-email-100" />
                        <span asp-validation-for="CorreoElectronico" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="IdRolTienda" class="form-label fw-semibold">Rol interno</label>

                        @if (ViewBag.EsAdminRolFijo != null && (bool)ViewBag.EsAdminRolFijo)
                        {
                            <input type="hidden" asp-for="IdRolTienda" />
                            <input class="form-control" value="Admin tienda" disabled />
                            <small class="text-muted">El rol de admin_tienda no puede modificarse desde este módulo.</small>
                        }
                        else
                        {
                            <select asp-for="IdRolTienda" class="form-select" asp-items="ViewBag.RolesInternos">
                                <option value="">Selecciona un rol</option>
                            </select>
                        }

                        <span asp-validation-for="IdRolTienda" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Actualizar contraseña</h5>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="NuevaContrasena" class="form-label fw-semibold">Nueva contraseña</label>
                        <input asp-for="NuevaContrasena" class="form-control" type="password" />
                        <span asp-validation-for="NuevaContrasena" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ConfirmarNuevaContrasena" class="form-label fw-semibold">Confirmar nueva contraseña</label>
                        <input asp-for="ConfirmarNuevaContrasena" class="form-control" type="password" />
                        <span asp-validation-for="ConfirmarNuevaContrasena" class="text-danger"></span>
                    </div>
                </div>

                <div class="alert alert-info mt-4 mb-0">
                    Deja estos campos vacíos si no deseas cambiar la contraseña de esta cuenta.
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button type="submit" class="btn btn-dark">Guardar cambios</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}