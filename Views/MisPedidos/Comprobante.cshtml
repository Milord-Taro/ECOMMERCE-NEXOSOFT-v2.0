@model ECOMMERCE_NEXOSOFT.Models.Pedido

@{
    Layout = null;
    var subtotal = Model.Detallepedidos.Sum(x => x.Subtotal);
    var pago = Model.Ventum?.Pago;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Comprobante Pedido @Model.CodPedido</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            color: #263238;
            background: #f8f9fa;
        }

        .print-wrapper {
            padding: 30px;
        }

        .comprobante-box {
            max-width: 950px;
            margin: 0 auto;
            border: 1px solid #ddd;
            padding: 36px;
            border-radius: 14px;
            background: #fff;
        }

        .empresa {
            font-size: 1.35rem;
            font-weight: 700;
            color: #D32F2F;
            margin-bottom: 10px;
        }

        .titulo {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 14px;
            color: #1f2937;
        }

        .subtitulo {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 10px;
            color: #1f2937;
        }

        .info p {
            margin-bottom: 6px;
        }

        .table th {
            background: #f8f9fa;
        }

        .estado-badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 0.85rem;
            font-weight: 700;
        }

        .estado-pendiente {
            background: #ffc107;
            color: #212529;
        }

        .estado-en-camino {
            background: #0dcaf0;
            color: #212529;
        }

        .estado-entregado {
            background: #198754;
            color: #fff;
        }

        .estado-cancelado {
            background: #dc3545;
            color: #fff;
        }

        .estado-pago-aprobado {
            background: #198754;
            color: #fff;
        }

        .estado-pago-proceso {
            background: #ffc107;
            color: #212529;
        }

        .estado-pago-desaprobado {
            background: #dc3545;
            color: #fff;
        }

        .bloque {
            margin-bottom: 24px;
        }

        .acciones {
            margin-top: 30px;
        }

        @@page {
            size: auto;
            margin: 12mm;
        }

        @@media print {
            html, body {
                background: #fff !important;
                margin: 0 !important;
                padding: 0 !important;
            }

                body * {
                    visibility: hidden;
                }

            .comprobante-box, .comprobante-box * {
                visibility: visible;
            }

            .comprobante-box {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
                max-width: 100%;
                margin: 0;
                border: none;
                border-radius: 0;
                box-shadow: none;
                padding: 0;
            }

            .acciones {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <div class="print-wrapper">
        <div class="comprobante-box">
            <div class="row align-items-start mb-4">
                <div class="col-6">
                    <div class="empresa">NEXOSOFT SAS</div>
                    <p class="mb-0">Ferretería Ecommerce</p>
                    <p class="mb-0">Bogotá, Colombia</p>
                    <p class="mb-0">ventas@nexosoft.com.co</p>
                </div>

                <div class="col-6 text-end">
                    <div class="titulo">Comprobante</div>
                    <p class="mb-1"><strong>Código:</strong> @Model.CodPedido</p>
                    <p class="mb-1"><strong>Fecha:</strong> @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</p>
                    <p class="mb-1">
                        <strong>Estado del pedido:</strong>
                        @if (Model.EstadoPedido == "pendiente")
                        {
                            <span class="estado-badge estado-pendiente">Pendiente</span>
                        }
                        else if (Model.EstadoPedido == "en camino")
                        {
                            <span class="estado-badge estado-en-camino">En camino</span>
                        }
                        else if (Model.EstadoPedido == "entregado")
                        {
                            <span class="estado-badge estado-entregado">Entregado</span>
                        }
                        else
                        {
                            <span class="estado-badge estado-cancelado">Cancelado</span>
                        }
                    </p>
                </div>
            </div>

            <hr />

            <div class="row bloque">
                <div class="col-md-6 info">
                    <div class="subtitulo">Información de entrega</div>
                    <p><strong>Cliente:</strong> @Model.IdUsuarioNavigation?.Nombre @Model.IdUsuarioNavigation?.Apellido</p>
                    <p><strong>Correo:</strong> @Model.IdUsuarioNavigation?.CorreoElectronico</p>
                    <p><strong>Tienda:</strong> @(Model.IdTiendaNavigation?.NombreTienda ?? "Sin tienda")</p>
                    <p><strong>Dirección de entrega:</strong> @(string.IsNullOrWhiteSpace(Model.DireccionEntrega) ? "No registrada" : Model.DireccionEntrega)</p>
                    <p><strong>Teléfono:</strong> @(string.IsNullOrWhiteSpace(Model.TelefonoEntrega) ? "No registrado" : Model.TelefonoEntrega)</p>
                    <p><strong>Método de entrega:</strong> @(string.IsNullOrWhiteSpace(Model.MetodoEntrega) ? "No definido" : Model.MetodoEntrega)</p>
                </div>

                <div class="col-md-6 info">
                    <div class="subtitulo">Información del pago</div>
                    <p><strong>Método de pago:</strong> @(string.IsNullOrWhiteSpace(pago?.MetodoPago) ? "No registrado" : pago.MetodoPago)</p>
                    <p>
                        <strong>Estado del pago:</strong>
                        @if (string.IsNullOrWhiteSpace(pago?.EstadoPago))
                        {
                            <span>No registrado</span>
                        }
                        else if (pago.EstadoPago == "aprobado")
                        {
                            <span class="estado-badge estado-pago-aprobado">Aprobado</span>
                        }
                        else if (pago.EstadoPago == "enproceso")
                        {
                            <span class="estado-badge estado-pago-proceso">En proceso</span>
                        }
                        else
                        {
                            <span class="estado-badge estado-pago-desaprobado">Desaprobado</span>
                        }
                    </p>
                    <p><strong>Código de autorización:</strong> @(string.IsNullOrWhiteSpace(pago?.CodigoAutorizacion) ? "No registrado" : pago.CodigoAutorizacion)</p>
                    <p><strong>Detalle del pago:</strong> @(string.IsNullOrWhiteSpace(pago?.Descripcion) ? "Sin observaciones" : pago.Descripcion)</p>
                    <p><strong>Fecha del pago:</strong> @(pago?.FechaPago.ToString("dd/MM/yyyy HH:mm") ?? "No registrada")</p>
                </div>
            </div>

            <div class="table-responsive bloque">
                <table class="table table-bordered align-middle">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Precio unitario</th>
                            <th>Cantidad</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Detallepedidos)
                        {
                            <tr>
                                <td>@item.IdProductoNavigation?.NombreProducto</td>
                                <td>@item.PrecioUnitario.ToString("C")</td>
                                <td>@item.Cantidad</td>
                                <td>@item.Subtotal.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="row">
                <div class="col-md-6"></div>
                <div class="col-md-6">
                    <div class="text-end">
                        <p class="mb-2"><strong>Subtotal:</strong> @subtotal.ToString("C")</p>
                        <p class="mb-2"><strong>Costo de envío:</strong> @Model.CostoEnvio.ToString("C")</p>
                        <h3 class="mb-0"><strong>Total:</strong> @Model.Total.ToString("C")</h3>
                    </div>
                </div>
            </div>

            <div class="acciones d-flex gap-2 flex-wrap">
                <button onclick="window.print()" class="btn btn-danger">
                    Imprimir / Guardar PDF
                </button>

                <a asp-controller="MisPedidos"
                   asp-action="Detalle"
                   asp-route-id="@Model.IdPedido"
                   class="btn btn-outline-secondary">
                    Volver al pedido
                </a>
            </div>
        </div>
    </div>
</body>
</html>