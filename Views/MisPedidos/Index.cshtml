@model IEnumerable<ECOMMERCE_NEXOSOFT.Models.Pedido>

@{
    ViewData["Title"] = "Mis pedidos";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1">Mis pedidos</h2>
            <p class="text-muted mb-0">Consulta el historial de compras realizadas en tu cuenta.</p>
        </div>

        <a asp-controller="Cliente" asp-action="Index" class="btn btn-outline-secondary">
            ← Volver a mi cuenta
        </a>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success">
            @TempData["MensajeExito"]
        </div>
    }

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger">
            @TempData["MensajeError"]
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Código</th>
                            <th>Fecha</th>
                            <th>Tienda</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    Aún no tienes pedidos registrados.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.CodPedido</td>
                                    <td>@item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@(item.IdTiendaNavigation?.NombreTienda ?? "Sin tienda")</td>
                                    <td>@item.Total.ToString("C")</td>
                                    <td>
                                        @if (item.EstadoPedido == "pendiente")
                                        {
                                            <span class="badge bg-warning text-dark">Pendiente</span>
                                        }
                                        else if (item.EstadoPedido == "en camino")
                                        {
                                            <span class="badge bg-info text-dark">En camino</span>
                                        }
                                        else if (item.EstadoPedido == "entregado")
                                        {
                                            <span class="badge bg-success">Entregado</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Cancelado</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Detalle"
                                           asp-route-id="@item.IdPedido"
                                           class="btn btn-sm btn-outline-dark">
                                            Detalle
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>