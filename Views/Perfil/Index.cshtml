@model ECOMMERCE_NEXOSOFT.ViewModels.PerfilViewModel

@{
    ViewData["Title"] = "Mi perfil";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1">Mi perfil personal</h2>
            <p class="text-muted mb-0">Consulta y actualiza tu información personal.</p>
        </div>

        @if (Model.IdRol != 1 && Model.IdRol != 3)
        {
            <a asp-controller="SolicitudVendedor" asp-action="MisSolicitudes" class="btn btn-outline-dark">
                Mis solicitudes de vendedor
            </a>

            <a asp-controller="SolicitudVendedor" asp-action="Create" class="btn btn-outline-dark">
                Quiero vender
            </a>
        }
        </div>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success">
            @TempData["MensajeExito"]
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <form asp-action="Index" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="IdUsuario" />
                <input type="hidden" asp-for="IdRol" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Nombre" class="form-label fw-semibold"></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Apellido" class="form-label fw-semibold"></label>
                        <input asp-for="Apellido" class="form-control" />
                        <span asp-validation-for="Apellido" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Telefono" class="form-label fw-semibold"></label>
                        <input asp-for="Telefono" class="form-control" />
                        <span asp-validation-for="Telefono" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CorreoElectronico" class="form-label fw-semibold"></label>
                        <input asp-for="CorreoElectronico" class="form-control" />
                        <span asp-validation-for="CorreoElectronico" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-semibold">Rol</label>
                        <input class="form-control"
                               value="@(Model.IdRol == 1 ? "Administrador" : Model.IdRol == 2 ? "Cliente" : Model.IdRol == 3 ? "Vendedor" : "Sin rol")"
                               disabled />
                    </div>
                </div>

            <div class="d-flex gap-2 mt-4 flex-wrap">
                <button type="submit" class="btn btn-dark">Guardar cambios</button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Volver</a>

                @if (Model.IdRol == 2)
                {
                    <a asp-controller="SolicitudVendedor" asp-action="MisSolicitudes" class="btn btn-outline-dark">
                        Mis solicitudes de vendedor
                    </a>
                    <a asp-controller="SolicitudVendedor" asp-action="Create" class="btn btn-outline-dark">
                        Quiero vender
                    </a>
                }

                @if (Model.IdRol == 3)
                {
                    <a asp-controller="MiTienda" asp-action="Index" class="btn btn-outline-dark">
                        Mi perfil tienda
                    </a>
                    <a asp-controller="MisPedidos" asp-action="Index" class="btn btn-outline-dark">
                        Mis pedidos
                    </a>
                    <a asp-controller="Vendedor" asp-action="Index" class="btn btn-outline-dark">
                        Panel vendedor
                    </a>
                }
            </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}