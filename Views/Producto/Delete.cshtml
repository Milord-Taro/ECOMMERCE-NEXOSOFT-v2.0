@model ECOMMERCE_NEXOSOFT.Models.Producto

@{
    ViewData["Title"] = "Ocultar producto";
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Ocultar producto</h2>
        <p class="text-muted mb-0">Este producto dejará de mostrarse en el catálogo público, pero seguirá guardado en el sistema.</p>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <dl class="row mb-4">
                <dt class="col-sm-3">Código</dt>
                <dd class="col-sm-9">@Model.CodProducto</dd>

                <dt class="col-sm-3">Nombre</dt>
                <dd class="col-sm-9">@Model.NombreProducto</dd>

                <dt class="col-sm-3">Marca</dt>
                <dd class="col-sm-9">@Model.MarcaProducto</dd>

                <dt class="col-sm-3">Precio venta</dt>
                <dd class="col-sm-9">@Model.PrecioVentaProducto.ToString("C")</dd>

                <dt class="col-sm-3">Categoría</dt>
                <dd class="col-sm-9">@Model.IdCategoriaNavigation?.NombreCategoria</dd>

                <dt class="col-sm-3">Estado actual</dt>
                <dd class="col-sm-9">
                    @if (Model.VisiblePublico)
                    {
                        <span class="badge bg-success">Publicado</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Oculto</span>
                    }
                </dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="IdProducto" />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Confirmar ocultar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>