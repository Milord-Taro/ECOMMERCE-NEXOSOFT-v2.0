@model ECOMMERCE_NEXOSOFT.Models.Producto

@{
    ViewData["Title"] = "Detalle del producto";
    bool tieneStock = Model.Stock != null;
    bool stockBajo = Model.Stock != null && Model.Stock.StockActual <= Model.Stock.StockMinimo;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1">Detalle del producto</h2>
            <p class="text-muted mb-0">Consulta la información general y el estado actual del producto.</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.IdProducto" class="btn btn-dark">Editar producto</a>

            @if (tieneStock)
            {
                <a asp-controller="Stock" asp-action="Edit" asp-route-id="@Model.Stock?.IdInventario" class="btn btn-outline-dark">
                    Editar stock
                </a>
            }

            <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-md-6">
                    <h5 class="fw-bold mb-3">Información general</h5>

                    <dl class="row mb-0">
                        <dt class="col-sm-5">Código</dt>
                        <dd class="col-sm-7">@Model.CodProducto</dd>

                        <dt class="col-sm-5">Nombre</dt>
                        <dd class="col-sm-7">@Model.NombreProducto</dd>

                        <dt class="col-sm-5">Descripción</dt>
                        <dd class="col-sm-7">@Model.DescripcionCorta</dd>

                        <dt class="col-sm-5">SKU</dt>
                        <dd class="col-sm-7">@Model.SkuProducto</dd>

                        <dt class="col-sm-5">Código de barras</dt>
                        <dd class="col-sm-7">@Model.CodigoBarrasProducto</dd>

                        <dt class="col-sm-5">Unidad de medida</dt>
                        <dd class="col-sm-7">@Model.UnidadMedidaProducto</dd>

                        <dt class="col-sm-5">Marca</dt>
                        <dd class="col-sm-7">@Model.MarcaProducto</dd>

                        <dt class="col-sm-5">Precio de venta</dt>
                        <dd class="col-sm-7">@Model.PrecioVentaProducto.ToString("C")</dd>

                        <dt class="col-sm-5">Categoría</dt>
                        <dd class="col-sm-7">@Model.IdCategoriaNavigation?.NombreCategoria</dd>

                        <dt class="col-sm-5">Subcategoría</dt>
                        <dd class="col-sm-7">@Model.IdSubcategoriaNavigation?.NombreSubcategoria</dd>

                        <dt class="col-sm-5">Tienda</dt>
                        <dd class="col-sm-7">@Model.IdTiendaNavigation?.NombreTienda</dd>
                    </dl>
                </div>

                <div class="col-md-6">
                    <h5 class="fw-bold mb-3">Estado del producto</h5>

                    <dl class="row mb-0">
                        <dt class="col-sm-5">Favorito</dt>
                        <dd class="col-sm-7">
                            @if (Model.Favorito)
                            {
                                <span class="badge bg-warning text-dark">Sí</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </dd>

                        <dt class="col-sm-5">Visibilidad</dt>
                        <dd class="col-sm-7">
                            @if (Model.VisiblePublico)
                            {
                                <span class="badge bg-success">Publicado</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Oculto</span>
                            }
                        </dd>

                        <dt class="col-sm-5">Stock actual</dt>
                        <dd class="col-sm-7">
                            @if (tieneStock)
                            {
                                @(Model.Stock?.StockActual ?? 0)
                            }
                            else
                            {
                                <span class="badge bg-danger">Sin registro</span>
                            }
                        </dd>

                        <dt class="col-sm-5">Stock mínimo</dt>
                        <dd class="col-sm-7">
                            @if (tieneStock)
                            {
                                @(Model.Stock?.StockMinimo ?? 0)
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </dd>

                        <dt class="col-sm-5">Precio compra</dt>
                        <dd class="col-sm-7">
                            @if (tieneStock)
                            {
                                @((Model.Stock?.PrecioCompraStock ?? 0).ToString("C"))
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </dd>

                        <dt class="col-sm-5">Estado inventario</dt>
                        <dd class="col-sm-7">
                            @if (!tieneStock)
                            {
                                <span class="badge bg-danger">Sin stock registrado</span>
                            }
                            else if (stockBajo)
                            {
                                <span class="badge bg-warning text-dark">Stock bajo</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Disponible</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>