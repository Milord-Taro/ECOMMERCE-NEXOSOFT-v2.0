@model ECOMMERCE_NEXOSOFT.Models.Producto

@{
    ViewData["Title"] = "Detalle del producto";
}

<section class="container py-5">
    <div class="row g-5 align-items-start">

        <div class="col-md-5">
            <div class="product-card">
                <div class="product-image-wrap">
                    <img src="/img/producto-default.jpg" alt="@Model.NombreProducto" />
                    @if (Model.Favorito)
                    {
                        <span class="product-badge">Destacado</span>
                    }
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.DescripcionCorta))
            {
                <div class="mt-3">
                    <h6 class="fw-bold">Descripción</h6>
                    <p class="text-muted mb-0">@Model.DescripcionCorta</p>
                </div>
            }
        </div>

        <div class="col-md-7">
            <h2 class="section-title mb-3">@Model.NombreProducto</h2>

            @if (Model.IdTiendaNavigation != null)
            {
                <p class="mb-2">
                    <strong>Tienda:</strong>
                    <a asp-controller="Tiendas"
                       asp-action="Detalle"
                       asp-route-id="@Model.IdTienda"
                       class="text-decoration-none fw-semibold">
                        @Model.IdTiendaNavigation.NombreTienda
                    </a>
                </p>
            }

            <div class="mb-3 d-flex flex-wrap align-items-center">
                <span class="tag-label tag-categoria">
                    @Model.IdCategoriaNavigation.NombreCategoria
                </span>

                @if (Model.IdSubcategoriaNavigation != null)
                {
                    <span class="tag-label tag-subcategoria">
                        @Model.IdSubcategoriaNavigation.NombreSubcategoria
                    </span>
                }
            </div>

            @if (!string.IsNullOrEmpty(Model.MarcaProducto))
            {
                <p class="text-muted mb-2">
                    Marca: @Model.MarcaProducto
                </p>
            }

            <h3 class="price-current mb-3">
                $@Model.PrecioVentaProducto.ToString("N2")
            </h3>

            <p class="mb-2">
                <strong>Unidad:</strong> @Model.UnidadMedidaProducto
            </p>

            @if (Model.Stock != null)
            {
                <p class="mb-4">
                    <strong>Stock disponible:</strong> @Model.Stock.StockActual
                </p>
            }

            @if (TempData["MensajeCarrito"] != null)
            {
                <div class="alert alert-warning">
                    @TempData["MensajeCarrito"]
                </div>
            }

            @{
                bool tieneStock = Model.Stock != null && Model.Stock.StockActual > 0;
            }

            @if (TempData["MensajeCarrito"] != null)
            {
                <div class="alert alert-warning rounded-4">
                    @TempData["MensajeCarrito"]
                </div>
            }

            @if (tieneStock)
            {
                <form asp-controller="Carrito" asp-action="Agregar" method="get" class="mt-3">
                    <input type="hidden" name="id" value="@Model.IdProducto" />

                    <div class="row g-3 align-items-end">
                        <div class="col-sm-4">
                            <label for="cantidad" class="form-label fw-semibold">Cantidad</label>
                            <input type="number"
                                   id="cantidad"
                                   name="cantidad"
                                   value="1"
                                   min="1"
                                   max="@(Model.Stock?.StockActual ?? 1)"
                                   class="form-control" />
                            <small class="text-muted">
                                Disponible: @(Model.Stock?.StockActual ?? 0)
                            </small>
                        </div>

                        <div class="col-sm-8 d-grid d-sm-flex gap-2">
                            <button type="submit" class="btn btn-dark rounded-pill px-4">
                                Agregar al carrito
                            </button>

                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                                Volver al catálogo
                            </a>
                        </div>
                    </div>
                </form>
            }
            else
            {
                <div class="mt-3">
                    <span class="badge bg-danger mb-2">Sin stock</span>
                    <div>
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                            Volver al catálogo
                        </a>
                    </div>
                </div>
            }

        </div>
    </div>
</section>