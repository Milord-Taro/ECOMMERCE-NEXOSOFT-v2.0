@model List<ECOMMERCE_NEXOSOFT.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<section class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="section-title">Catálogo de productos</h2>
    </div>

    <div class="row g-4">
        @foreach (var producto in Model)
        {
            <div class="col-lg-3 col-md-4 col-6">
                <div class="product-card">
                    <div class="product-image-wrap">
                        <img src="/img/producto-default.jpg" alt="@producto.NombreProducto" />

                        @if (producto.Favorito)
                        {
                            <span class="product-badge">Destacado</span>
                        }
                    </div>

                    <div class="product-body">
                        <h6>@producto.NombreProducto</h6>

                        <p class="mb-1 text-muted">
                            @producto.IdCategoriaNavigation.NombreCategoria
                        </p>

                        <div class="product-price">
                            <span class="price-current">
                                $@producto.PrecioVentaProducto.ToString("N2")
                            </span>
                        </div>

                        <a asp-controller="Productos"
                           asp-action="Detalle"
                           asp-route-id="@producto.IdProducto"
                           class="btn btn-danger w-100">
                            Ver producto
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>