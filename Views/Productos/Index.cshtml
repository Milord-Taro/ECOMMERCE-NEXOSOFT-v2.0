@model IEnumerable<ECOMMERCE_NEXOSOFT.Models.Producto>
@using ECOMMERCE_NEXOSOFT.Models

@{
    ViewData["Title"] = "Catálogo";

    var categorias = ViewBag.Categorias as List<Categorium> ?? new List<Categorium>();
    var marcas = ViewBag.Marcas as List<string> ?? new List<string>();

    int? categoriaSeleccionada = ViewBag.CategoriaSeleccionada as int?;
    string busqueda = ViewBag.Busqueda as string ?? "";
    string marcaSeleccionada = ViewBag.MarcaSeleccionada as string ?? "";
    var subcategorias = ViewBag.Subcategorias as List<Subcategorium> ?? new List<Subcategorium>();
    int? subcategoriaSeleccionada = ViewBag.SubcategoriaSeleccionada as int?;
    string ordenSeleccionado = ViewBag.OrdenSeleccionado as string ?? "";
    bool soloDisponibles = ViewBag.SoloDisponibles != null && (bool)ViewBag.SoloDisponibles;
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Catálogo de productos</h2>
        <p class="text-muted mb-0">Explora productos disponibles para ferretería y hogar.</p>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body p-4">
            <form asp-action="Index" method="get">
                <div class="row g-3 align-items-end">

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Categoría</label>
                        <select name="categoria" id="categoriaFiltro" class="form-select">
                            <option value="">Todas</option>
                            @foreach (var categoria in categorias)
                            {
                                if (categoriaSeleccionada == categoria.IdCategoria)
                                {
                                    <option value="@categoria.IdCategoria" selected>@categoria.NombreCategoria</option>
                                }
                                else
                                {
                                    <option value="@categoria.IdCategoria">@categoria.NombreCategoria</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Subcategoría</label>
                        <select name="subcategoria" id="subcategoriaFiltro" class="form-select">
                            <option value="">Todas</option>
                            @foreach (var subcategoria in subcategorias)
                            {
                                if (subcategoriaSeleccionada == subcategoria.IdSubcategoria)
                                {
                                    <option value="@subcategoria.IdSubcategoria" selected>@subcategoria.NombreSubcategoria</option>
                                }
                                else
                                {
                                    <option value="@subcategoria.IdSubcategoria">@subcategoria.NombreSubcategoria</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-semibold">Marca</label>
                        <select name="marca" class="form-select">
                            <option value="">Todas</option>
                            @foreach (var marca in marcas)
                            {
                                if (marcaSeleccionada == marca)
                                {
                                    <option value="@marca" selected>@marca</option>
                                }
                                else
                                {
                                    <option value="@marca">@marca</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-semibold">Ordenar</label>
                        <select name="orden" class="form-select">
                            <option value="" selected="@(string.IsNullOrEmpty(ordenSeleccionado))">Nombre A-Z</option>
                            <option value="nombre_desc" selected="@(ordenSeleccionado == "nombre_desc")">Nombre Z-A</option>
                            <option value="precio_asc" selected="@(ordenSeleccionado == "precio_asc")">Precio menor</option>
                            <option value="precio_desc" selected="@(ordenSeleccionado == "precio_desc")">Precio mayor</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <div class="form-check mt-4 pt-2">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="soloDisponibles"
                                   value="true"
                                   id="soloDisponibles"
                                   @(soloDisponibles ? "checked" : "") />
                            <label class="form-check-label fw-semibold" for="soloDisponibles">
                                Solo disponibles
                            </label>
                        </div>
                    </div>

                    <div class="col-12 d-flex gap-2 pt-2">
                        <button type="submit" class="btn btn-dark px-4">
                            Filtrar
                        </button>

                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            Limpiar filtros
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0 fw-semibold">Resultados</h5>
        <span class="text-muted">@Model.Count() producto(s)</span>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light border rounded-4 shadow-sm">
            No se encontraron productos con los filtros seleccionados.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                bool tieneStock = item.Stock != null && item.Stock.StockActual > 0;

                <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                    <div class="card h-100 border-0 shadow-sm rounded-4">
                        <div class="card-body d-flex flex-column p-4">
                            <div class="mb-3">
                                <div class="bg-light rounded-4 d-flex align-items-center justify-content-center"
                                     style="height: 180px;">
                                    <img src="~/img/producto-default.jpg"
                                         alt="@item.NombreProducto"
                                         class="img-fluid"
                                         style="max-height: 140px;" />
                                </div>
                            </div>

                            <div class="mb-2 d-flex flex-wrap align-items-center">
                                <span class="tag-label tag-categoria">
                                    @item.IdCategoriaNavigation?.NombreCategoria
                                </span>

                                @if (item.IdSubcategoriaNavigation != null)
                                {
                                    <span class="tag-label tag-subcategoria">
                                        @item.IdSubcategoriaNavigation.NombreSubcategoria
                                    </span>
                                }
                            </div>

                            @if (item.IdTiendaNavigation != null)
                            {
                                <p class="small mb-2">
                                    <a asp-controller="Tiendas"
                                       asp-action="Detalle"
                                       asp-route-id="@item.IdTienda"
                                       class="text-decoration-none fw-semibold">
                                        @item.IdTiendaNavigation.NombreTienda
                                    </a>
                                </p>
                            }

                            <h5 class="fw-bold mb-2">@item.NombreProducto</h5>

                            <p class="text-muted small mb-2">
                                @(string.IsNullOrWhiteSpace(item.MarcaProducto) ? "Sin marca" : item.MarcaProducto)
                            </p>

                            <div class="mb-2">
                                <span class="fs-5 fw-bold">
                                    @item.PrecioVentaProducto.ToString("C")
                                </span>
                            </div>

                            <div class="mb-3">
                        @if (tieneStock)
                                {
                                    <span class="badge bg-success">Disponible</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Sin stock</span>
                                }
                            </div>

                            <div class="mt-auto d-grid gap-2">
                                <a asp-action="Detalle"
                                   asp-route-id="@item.IdProducto"
                                   class="btn btn-outline-dark rounded-pill">
                                    Ver detalle
                                </a>

                                @if (tieneStock)
                                {
                                    <a asp-controller="Carrito"
                                       asp-action="Agregar"
                                       asp-route-id="@item.IdProducto"
                                       class="btn btn-dark rounded-pill">
                                        Agregar al carrito
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-secondary rounded-pill" disabled>
                                        Sin disponibilidad
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const categoriaSelect = document.getElementById("categoriaFiltro");
            const subcategoriaSelect = document.getElementById("subcategoriaFiltro");
            const selectedSubcategoria = "@(ViewBag.SubcategoriaSeleccionada ?? "")";

            function cargarSubcategorias() {
                const idCategoria = categoriaSelect.value;

                subcategoriaSelect.innerHTML = '<option value="">Todas</option>';

                if (!idCategoria) {
                    return;
                }

                fetch(`/Productos/ObtenerSubcategorias?idCategoria=${idCategoria}`)
                    .then(response => response.json())
                    .then(data => {
                        data.forEach(item => {
                            const option = document.createElement("option");
                            option.value = item.idSubcategoria;
                            option.text = item.nombreSubcategoria;

                            if (item.idSubcategoria == selectedSubcategoria) {
                                option.selected = true;
                            }

                            subcategoriaSelect.appendChild(option);
                        });
                    })
                    .catch(error => {
                        console.error("Error cargando subcategorías:", error);
                    });
            }

            categoriaSelect.addEventListener("change", cargarSubcategorias);
            cargarSubcategorias();
        });
    </script>
}