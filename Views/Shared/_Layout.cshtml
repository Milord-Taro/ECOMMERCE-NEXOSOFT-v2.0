@using ECOMMERCE_NEXOSOFT.Helpers
@using ECOMMERCE_NEXOSOFT.Models
@using Microsoft.AspNetCore.Http

@{
    var usuarioSesion = Context.Session.GetString("Usuario");
    var rolSesion = Context.Session.GetInt32("Rol");
    var carrito = Context.Session.GetObjectFromJson<List<CarritoItem>>("CARRITO") ?? new List<CarritoItem>();
    var cantidadCarrito = CarritoHelper.ObtenerCantidadItems(carrito);
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nexosoft Ferretería</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div class="top-bar text-white py-2">
            <div class="container text-center">
                <div class="big fw-semibold">
                    Envío gratis en compras superiores a $150.000
                </div>
            </div>
        </div>

        <div class="main-header py-3 bg-white shadow-sm">
            <div class="container">
                <div class="row align-items-center g-3">

                    <!-- LOGO -->
                    <div class="col-12 col-md-3">
                        <a asp-controller="Home" asp-action="Index">
                            <img src="/img/logo-nexosoft.png" alt="Nexosoft" height="40">
                        </a>
                    </div>

                    <!-- BUSCADOR -->
                    <div class="col-12 col-md-6">
                        <form asp-controller="Productos" asp-action="Index" method="get" class="d-flex search-box" role="search">
                            <input class="form-control search-input"
                                   type="search"
                                   name="buscar"
                                   value="@(ViewBag.Busqueda ?? "")"
                                   placeholder="Buscar productos, marcas o categorías..." />

                            <button class="btn btn-danger search-btn" type="submit">Buscar</button>
                        </form>
                    </div>

                    <!-- LOGIN / CARRITO -->
                    <div class="col-12 col-md-3">
                        <div class="d-flex align-items-center gap-3 ms-auto">
                            @if (string.IsNullOrEmpty(usuarioSesion))
                            {
                                <a asp-controller="Auth" asp-action="Login" class="header-link">Ingresar</a>

                                <a asp-controller="Carrito" asp-action="Index" class="cart-link position-relative" title="Carrito">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .49.402L2.89 3H14.5a.5.5 0 0 1 .49.598l-1.5 7A.5.5 0 0 1 13 11H4a.5.5 0 0 1-.49-.402L1.61 2H.5A.5.5 0 0 1 0 1.5M3.102 4l1.313 6h8.184l1.286-6z" />
                                        <path d="M5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4m0 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2m7-1a2 2 0 1 0 0 4 2 2 0 0 0 0-4m0 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2" />
                                    </svg>

                                    @if (cantidadCarrito > 0)
                                    {
                                        <span class="cart-badge">@cantidadCarrito</span>
                                    }
                                </a>
                            }
                            else
                            {
                                <div class="dropdown">
                                    <a class="header-link fw-semibold dropdown-toggle"
                                       href="#"
                                       role="button"
                                       data-bs-toggle="dropdown"
                                       aria-expanded="false">
                                        Hola, @usuarioSesion
                                    </a>

                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                        <li>
                                            <a class="dropdown-item" asp-controller="Perfil" asp-action="Index">
                                                Mi perfil
                                            </a>
                                        </li>

                                        @if (rolSesion == 1)
                                        {
                                            <li>
                                                <a class="dropdown-item" asp-controller="Admin" asp-action="Index">
                                                    Panel admin
                                                </a>
                                            </li>
                                        }
                                        else if (rolSesion == 2)
                                        {
                                            <li>
                                                <a class="dropdown-item" asp-controller="Cliente" asp-action="Index">
                                                    Mi cuenta
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" asp-controller="MisPedidos" asp-action="Index">
                                                    Mis pedidos
                                                </a>
                                            </li>
                                        }
                                        else if (rolSesion == 3)
                                        {
                                            <li>
                                                <a class="dropdown-item" asp-controller="Vendedor" asp-action="Index">
                                                    Panel vendedor
                                                </a>
                                            </li>
                                        }

                                        <li><hr class="dropdown-divider"></li>

                                        <li>
                                            <a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">
                                                Cerrar sesión
                                            </a>
                                        </li>
                                    </ul>
                                </div>

                                @if (rolSesion == 2)
                                {
                                    <a asp-controller="Carrito" asp-action="Index" class="cart-link position-relative" title="Carrito">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .49.402L2.89 3H14.5a.5.5 0 0 1 .49.598l-1.5 7A.5.5 0 0 1 13 11H4a.5.5 0 0 1-.49-.402L1.61 2H.5A.5.5 0 0 1 0 1.5M3.102 4l1.313 6h8.184l1.286-6z" />
                                            <path d="M5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4m0 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2m7-1a2 2 0 1 0 0 4 2 2 0 0 0 0-4m0 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2" />
                                        </svg>

                                        @if (cantidadCarrito > 0)
                                        {
                                            <span class="cart-badge">@cantidadCarrito</span>
                                        }
                                    </a>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <nav class="category-nav">
            <div class="container">
                <ul class="nav nav-pills flex-nowrap overflow-auto py-2 category-menu justify-content-center">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Categoria" asp-action="Index">Categorías</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Productos</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Ofertas</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Nosotros</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Contacto</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer text-white mt-5">
        <div class="container py-5">
            <div class="row g-4">
                <div class="col-12 col-md-6 col-lg-3">
                    <h4 class="footer-brand mb-3">NEXOSOFT SAS</h4>
                    <p class="footer-text">
                        Tu aliado en ferretería profesional. Innovación, confianza y tecnología al servicio de tus proyectos.
                    </p>
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    <h5 class="footer-title">Información</h5>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Sobre nosotros</a></li>
                        <li><a href="#">Términos y condiciones</a></li>
                        <li><a href="#">Política de privacidad</a></li>
                        <li><a href="#">Preguntas frecuentes</a></li>
                    </ul>
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    <h5 class="footer-title">Atención al cliente</h5>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Seguimiento de pedido</a></li>
                        <li><a href="#">Cambios y devoluciones</a></li>
                        <li><a href="#">Métodos de pago</a></li>
                        <li><a href="#">Garantías</a></li>
                    </ul>
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    <h5 class="footer-title">Contacto</h5>
                    <ul class="list-unstyled footer-contact">
                        <li>+57 (601) 234 5678</li>
                        <li>+57 300 123 4567</li>
                        <li>ventas@nexosoft.com.co</li>
                        <li>Bogotá, Colombia</li>
                    </ul>
                </div>
            </div>

            <hr class="footer-line my-4" />

            <div class="text-center footer-copy">

                &copy; 2026 NEXOSOFT SAS. Todos los derechos reservados.

                <div class="mt-2">
                    <a asp-controller="Home"
                       asp-action="Error500"
                       class="btn btn-sm btn-outline-light">
                        Test Error 500
                    </a>
                </div>

            </div>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
