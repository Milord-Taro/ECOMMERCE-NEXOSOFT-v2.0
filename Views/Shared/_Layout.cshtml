<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nexosoft Ferretería</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <!-- Barra superior -->
        <div class="top-bar text-white py-2">
            <div class="container text-center">
                <div class="big fw-semibold" >
                    Envío gratis en compras superiores a $150.000
                </div>
            </div>
        </div>

        <!-- Header principal -->
        <div class="main-header py-3 bg-white shadow-sm">
            <div class="container">
                <div class="row align-items-center g-3">
                    <!-- Logo -->
                    <div class="col-12 col-md-3 text-center text-md-start">
                        <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                            <img src="~/img/logo-nexosoft.png" alt="Nexosoft" class="logo-nexosoft img-fluid" />
                        </a>
                    </div>

                    <!-- Buscador -->
                    <div class="col-12 col-md-6">
                        <form class="d-flex search-box" role="search">
                            <input class="form-control search-input" type="search" placeholder="Buscar productos, marcas o categorías..." />
                            <button class="btn btn-danger search-btn" type="submit">Buscar</button>
                        </form>
                    </div>

                    <!-- Acciones -->
                    <div class="col-12 col-md-3">
                        <div class="d-flex justify-content-center justify-content-md-end align-items-center gap-3">
                            <a href="#" class="header-icon text-decoration-none">Mi cuenta</a>
                            <a href="#" class="header-icon text-decoration-none position-relative">
                                Carrito
                                <span class="cart-badge">3</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Menú navegación -->
        <nav class="category-nav">
            <div class="container">
                <ul class="nav nav-pills flex-nowrap overflow-auto py-2 category-menu justify-content-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Categoria" asp-action="Index">Categorías</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Productos</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Ofertas</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Nosotros</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Contacto</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer text-white mt-5">
        <div class="container py-5">
            <div class="row g-4">
                <div class="col-12 col-md-6 col-lg-3">
                    <h4 class="footer-brand mb-3">NEXOSOFT SAS</h4>
                    <p class="footer-text">
                        Tu aliado en ferretería profesional. Innovación, confianza y tecnología al servicio de tus proyectos.
                    </p>
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    <h5 class="footer-title">Información</h5>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Sobre nosotros</a></li>
                        <li><a href="#">Términos y condiciones</a></li>
                        <li><a href="#">Política de privacidad</a></li>
                        <li><a href="#">Preguntas frecuentes</a></li>
                    </ul>
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    <h5 class="footer-title">Atención al cliente</h5>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Seguimiento de pedido</a></li>
                        <li><a href="#">Cambios y devoluciones</a></li>
                        <li><a href="#">Métodos de pago</a></li>
                        <li><a href="#">Garantías</a></li>
                    </ul>
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    <h5 class="footer-title">Contacto</h5>
                    <ul class="list-unstyled footer-contact">
                        <li>+57 (601) 234 5678</li>
                        <li>+57 300 123 4567</li>
                        <li>ventas@nexosoft.com.co</li>
                        <li>Bogotá, Colombia</li>
                    </ul>
                </div>
            </div>

            <hr class="footer-line my-4" />

            <div class="text-center footer-copy">
                &copy; 2026 NEXOSOFT SAS. Todos los derechos reservados.
            </div>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>