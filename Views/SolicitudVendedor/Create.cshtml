@model ECOMMERCE_NEXOSOFT.ViewModels.SolicitudVendedorViewModel

@{
    ViewData["Title"] = "Solicitar cuenta de vendedor";
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Solicitar cuenta de vendedor</h2>
        <p class="text-muted mb-0">Envía tu solicitud para vender en el marketplace con tu propia tienda.</p>
    </div>

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger">
            @TempData["MensajeError"]
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-12">
                        <label asp-for="NombreTiendaSolicitada" class="form-label fw-semibold">Nombre de la tienda</label>
                        <input asp-for="NombreTiendaSolicitada" class="form-control" />
                        <span asp-validation-for="NombreTiendaSolicitada" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="DescripcionTienda" class="form-label fw-semibold">Descripción</label>
                        <textarea asp-for="DescripcionTienda" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="DescripcionTienda" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-dark">Enviar solicitud</button>
                    <a asp-controller="Perfil" asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}