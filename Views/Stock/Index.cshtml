@model IEnumerable<ECOMMERCE_NEXOSOFT.Models.Stock>

@{
    ViewData["Title"] = "Stock de mi tienda";
    var busqueda = ViewBag.Busqueda as string;
    var soloStockBajo = ViewBag.SoloStockBajo as bool?;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1">Stock de mi tienda</h2>
            <p class="text-muted mb-0">Consulta el inventario actual y registra movimientos de stock.</p>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="Stock" asp-action="Movimientos" class="btn btn-outline-dark">
                Ver movimientos
            </a>

            <a asp-controller="Vendedor" asp-action="Index" class="btn btn-outline-secondary">
                ← Volver al panel vendedor
            </a>
        </div>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success rounded-4">
            @TempData["MensajeExito"]
        </div>
    }

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger rounded-4">
            @TempData["MensajeError"]
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body p-4">
            <form method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label fw-semibold">Buscar producto</label>
                        <input type="text"
                               name="buscar"
                               value="@busqueda"
                               class="form-control"
                               placeholder="Nombre del producto" />
                    </div>

                    <div class="col-md-3">
                        <div class="form-check mt-4 pt-2">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="soloStockBajo"
                                   value="true"
                                   id="soloStockBajo"
                                   @(soloStockBajo == true ? "checked" : null) />
                            <label class="form-check-label" for="soloStockBajo">
                                Mostrar solo stock bajo
                            </label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <button type="submit" class="btn btn-dark">Filtrar</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Producto</th>
                            <th>Categoría</th>
                            <th>Precio compra</th>
                            <th>Stock actual</th>
                            <th>Stock mínimo</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    No se encontraron registros de stock con los filtros seleccionados.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                var stockBajo = item.StockActual <= item.StockMinimo;

                                <tr class="@(stockBajo ? "table-warning" : "")">
                                    <td>@item.IdProductoNavigation?.NombreProducto</td>
                                    <td>@item.IdProductoNavigation?.IdCategoriaNavigation?.NombreCategoria</td>
                                    <td>@item.PrecioCompraStock.ToString("C")</td>
                                    <td>@item.StockActual</td>
                                    <td>@item.StockMinimo</td>
                                    <td>
                                        @if (item.StockActual == 0)
                                        {
                                            <span class="badge bg-danger">Agotado</span>
                                        }
                                        else if (stockBajo)
                                        {
                                            <span class="badge bg-warning text-dark">Stock bajo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Normal</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Edit"
                                           asp-route-id="@item.IdInventario"
                                           class="btn btn-dark">
                                            Gestionar
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>