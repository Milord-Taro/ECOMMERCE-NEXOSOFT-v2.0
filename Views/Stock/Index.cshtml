@model IEnumerable<ECOMMERCE_NEXOSOFT.Models.Stock>

@{
    ViewData["Title"] = "Inventario";
    string busqueda = ViewBag.Busqueda as string ?? "";
    bool soloStockBajo = ViewBag.SoloStockBajo != null && (bool)ViewBag.SoloStockBajo;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1">Inventario / Stock</h2>
            <p class="text-muted mb-0">Administra cantidades disponibles de tus productos.</p>
        </div>
        <a asp-controller="Producto" asp-action="Index" class="btn btn-outline-dark">
            Ir a productos
        </a>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success">
            @TempData["MensajeExito"]
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body p-4">
            <form asp-action="Index" method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label fw-semibold">Buscar producto</label>
                        <input type="text"
                               name="buscar"
                               value="@busqueda"
                               class="form-control"
                               placeholder="Nombre del producto" />
                    </div>

                    <div class="col-md-3">
                        <div class="form-check mt-4 pt-2">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="soloStockBajo"
                                   value="true"
                                   id="soloStockBajo"
                                   @(soloStockBajo ? "checked" : "") />
                            <label class="form-check-label fw-semibold" for="soloStockBajo">
                                Solo stock bajo
                            </label>
                        </div>
                    </div>

                    <div class="col-md-4 d-flex gap-2">
                        <button type="submit" class="btn btn-dark">
                            Filtrar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Limpiar filtros
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Producto</th>
                            <th>Categoría</th>
                            <th>Precio compra</th>
                            <th>Stock actual</th>
                            <th>Stock mínimo</th>
                            <th>Estado</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            bool stockBajo = item.StockActual <= item.StockMinimo;

                            <tr class="@(stockBajo ? "table-warning" : "")">
                                <td>@item.IdProductoNavigation?.NombreProducto</td>
                                <td>@item.IdProductoNavigation?.IdCategoriaNavigation?.NombreCategoria</td>
                                <td>@item.PrecioCompraStock.ToString("C")</td>
                                <td>@item.StockActual</td>
                                <td>@item.StockMinimo</td>
                                <td>
                                    @if (stockBajo)
                                    {
                                        <span class="badge bg-warning text-dark">Stock bajo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Disponible</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.IdInventario" class="btn btn-sm btn-dark">
                                        Editar stock
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>