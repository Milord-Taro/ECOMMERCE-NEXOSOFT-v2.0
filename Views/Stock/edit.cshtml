@model ECOMMERCE_NEXOSOFT.ViewModels.StockMovimientoViewModel

@{
    ViewData["Title"] = "Gestionar stock";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1">Gestionar stock</h2>
            <p class="text-muted mb-0">Registra movimientos de inventario y actualiza parámetros del stock.</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            ← Volver al stock
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="IdInventario" />
                <input type="hidden" asp-for="CodInventario" />
                <input type="hidden" asp-for="IdProducto" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Producto</label>
                        <input class="form-control" value="@Model.NombreProducto" readonly />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Stock actual</label>
                        <input class="form-control" value="@Model.StockActual" readonly />
                    </div>

                    <div class="col-md-3">
                        <label asp-for="StockMinimo" class="form-label fw-semibold">Stock mínimo</label>
                        <input asp-for="StockMinimo" class="form-control" />
                        <span asp-validation-for="StockMinimo" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="PrecioCompraStock" class="form-label fw-semibold">Precio compra stock (Por unidad)</label>
                        <input asp-for="PrecioCompraStock" class="form-control" />
                        <span asp-validation-for="PrecioCompraStock" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="TipoMovimiento" class="form-label fw-semibold">Tipo de movimiento</label>
                        <select asp-for="TipoMovimiento" class="form-select">
                            <option value="">Selecciona una opción</option>
                            <option value="entrada">Entrada</option>
                            <option value="salida">Salida</option>
                            <option value="ajuste_positivo">Ajuste positivo</option>
                            <option value="ajuste_negativo">Ajuste negativo</option>
                        </select>
                        <span asp-validation-for="TipoMovimiento" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Cantidad" class="form-label fw-semibold">Cantidad</label>
                        <input asp-for="Cantidad" class="form-control" />
                        <span asp-validation-for="Cantidad" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Motivo" class="form-label fw-semibold">Motivo / observación</label>
                        <textarea asp-for="Motivo" class="form-control" rows="3" placeholder="Ej: Compra a proveedor, corrección de inventario, salida por venta interna, etc."></textarea>
                        <span asp-validation-for="Motivo" class="text-danger"></span>
                    </div>
                </div>

                <div class="alert alert-info mt-4 mb-0">
                    El sistema calcula automáticamente el nuevo stock. No debes escribir el saldo final manualmente.
                </div>

                <div class="d-flex gap-2 mt-4 flex-wrap">
                    <button type="submit" class="btn btn-dark">Guardar movimiento</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}