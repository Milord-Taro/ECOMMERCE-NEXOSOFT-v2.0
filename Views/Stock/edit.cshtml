@model ECOMMERCE_NEXOSOFT.Models.Stock

@{
    ViewData["Title"] = "Editar Stock";
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Editar stock</h2>
        <p class="text-muted mb-0">
            Producto: <strong>@Model.IdProductoNavigation?.NombreProducto</strong>
        </p>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="IdInventario" />
                <input type="hidden" asp-for="CodInventario" />
                <input type="hidden" asp-for="IdProducto" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Precio de compra</label>
                    <input asp-for="PrecioCompraStock" class="form-control" />
                    <span asp-validation-for="PrecioCompraStock" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Stock actual</label>
                    <input asp-for="StockActual" class="form-control" />
                    <span asp-validation-for="StockActual" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Stock mínimo</label>
                    <input asp-for="StockMinimo" class="form-control" />
                    <span asp-validation-for="StockMinimo" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-dark">Guardar cambios</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}