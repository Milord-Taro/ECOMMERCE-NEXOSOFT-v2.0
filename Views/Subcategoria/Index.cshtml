@model IEnumerable<ECOMMERCE_NEXOSOFT.Models.Subcategorium>

@{
    ViewData["Title"] = "Subcategorías";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1">Subcategorías</h2>
            <p class="text-muted mb-0">Administra las subcategorías del catálogo.</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-dark">
                Nueva subcategoría
            </a>
            <a asp-controller="Categoria" asp-action="Index" class="btn btn-outline-dark">
                Ir a categorías
            </a>
        </div>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success">
            @TempData["MensajeExito"]
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Código</th>
                            <th>Subcategoría</th>
                            <th>Categoría</th>
                            <th>Visible</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.CodSubcategoria</td>
                                <td>@item.NombreSubcategoria</td>
                                <td>@item.IdCategoriaNavigation?.NombreCategoria</td>
                                <td>
                                    @if (item.VisiblePublico)
                                    {
                                        <span class="badge bg-success">Sí</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">No</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end flex-wrap gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.IdSubcategoria" class="btn btn-sm btn-outline-dark">Editar</a>
                                        <a asp-action="Details" asp-route-id="@item.IdSubcategoria" class="btn btn-sm btn-outline-secondary">Detalle</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>