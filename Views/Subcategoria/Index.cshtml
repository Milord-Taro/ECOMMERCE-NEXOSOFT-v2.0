@model IEnumerable<ECOMMERCE_NEXOSOFT.Models.Subcategorium>
@using ECOMMERCE_NEXOSOFT.Models

@{
    ViewData["Title"] = "Subcategorías";
    var categoriasFiltro = ViewBag.CategoriasFiltro as List<Categorium> ?? new List<Categorium>();
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1">Subcategorías</h2>
            <p class="text-muted mb-0">Administra las subcategorías del catálogo.</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-dark">Nueva subcategoría</a>
            <a asp-controller="Categoria" asp-action="Index" class="btn btn-outline-dark">Ir a categorías</a>
        </div>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success">
            @TempData["MensajeExito"]
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body p-4">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Buscar</label>
                    <input type="text"
                           name="buscar"
                           value="@ViewBag.Buscar"
                           class="form-control"
                           placeholder="Código o nombre de subcategoría" />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Categoría</label>
                    <select name="categoria" class="form-select">
                        <option value="">Todas</option>
                        @foreach (var categoria in categoriasFiltro)
                        {
                            if (ViewBag.CategoriaSeleccionada != null && ViewBag.CategoriaSeleccionada == categoria.IdCategoria)
                            {
                                <option value="@categoria.IdCategoria" selected>@categoria.NombreCategoria</option>
                            }
                            else
                            {
                                <option value="@categoria.IdCategoria">@categoria.NombreCategoria</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Visibilidad</label>
                    <select name="visible" class="form-select">
                        <option value="">Todas</option>
                        @if (ViewBag.Visible != null && ViewBag.Visible == true)
                        {
                            <option value="true" selected>Visibles</option>
                        }
                        else
                        {
                            <option value="true">Visibles</option>
                        }

                        @if (ViewBag.Visible != null && ViewBag.Visible == false)
                        {
                            <option value="false" selected>Ocultas</option>
                        }
                        else
                        {
                            <option value="false">Ocultas</option>
                        }
                    </select>
                </div>

                <div class="col-md-2 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-dark w-100">Buscar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">Limpiar</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Código</th>
                            <th>Subcategoría</th>
                            <th>Categoría</th>
                            <th>Visible</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.CodSubcategoria</td>
                                <td>@item.NombreSubcategoria</td>
                                <td>@(item.IdCategoriaNavigation?.NombreCategoria ?? "Sin categoría")</td>
                                <td>
                                    @if (item.VisiblePublico)
                                    {
                                        <span class="badge bg-success">Sí</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">No</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end flex-wrap gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.IdSubcategoria" class="btn btn-sm btn-outline-dark">Editar</a>
                                        <a asp-action="Details" asp-route-id="@item.IdSubcategoria" class="btn btn-sm btn-outline-secondary">Detalle</a>
                                    </div>
                                </td>
                            </tr>
                        }

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">
                                    No se encontraron subcategorías.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>