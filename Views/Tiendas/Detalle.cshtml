@model ECOMMERCE_NEXOSOFT.Models.Tienda

@{
    ViewData["Title"] = Model.NombreTienda;
}

<div class="container py-4">
    <div class="mb-4">
        <a asp-controller="Productos" asp-action="Index" class="btn btn-outline-secondary mb-3">
            ← Volver al catálogo
        </a>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">
                <div class="row align-items-center g-4">
                    <div class="col-md-3 text-center">
                        @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
                        {
                            <img src="@Model.LogoUrl" alt="@Model.NombreTienda" class="img-fluid rounded-4" style="max-height: 140px;" />
                        }
                        else
                        {
                            <div class="bg-light rounded-4 d-flex align-items-center justify-content-center" style="height: 140px;">
                                <span class="text-muted">Sin logo</span>
                            </div>
                        }
                    </div>

                    <div class="col-md-9">
                        <h2 class="fw-bold mb-2">@Model.NombreTienda</h2>
                        <p class="text-muted mb-0">
                            @(string.IsNullOrWhiteSpace(Model.Descripcion)
                                                        ? "Esta tienda no ha agregado una descripción todavía."
                                                        : Model.Descripcion)
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold mb-0">Productos de esta tienda</h4>
        <span class="text-muted">@Model.Productos.Count producto(s)</span>
    </div>

    @if (!Model.Productos.Any())
    {
        <div class="alert alert-light border rounded-4 shadow-sm">
            Esta tienda no tiene productos públicos disponibles.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model.Productos.OrderBy(p => p.NombreProducto))
            {
                <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                    <div class="card h-100 border-0 shadow-sm rounded-4">
                        <div class="card-body d-flex flex-column p-3">
                            <div class="mb-3">
                                <div class="bg-light rounded-4 d-flex align-items-center justify-content-center" style="height: 180px;">
                                    <img src="~/img/producto-default.jpg"
                                         alt="@item.NombreProducto"
                                         class="img-fluid"
                                         style="max-height: 140px;" />
                                </div>
                            </div>

                            <div class="mb-2 d-flex flex-wrap align-items-center">
                                <span class="tag-label tag-categoria">
                                    @item.IdCategoriaNavigation?.NombreCategoria
                                </span>

                                @if (item.IdSubcategoriaNavigation != null)
                                {
                                    <span class="tag-label tag-subcategoria">
                                        @item.IdSubcategoriaNavigation.NombreSubcategoria
                                    </span>
                                }
                            </div>

                        <h5 class="fw-bold mb-2">@item.NombreProducto</h5>

                            <div class="mt-auto">
                                <p class="fw-bold fs-5 mb-3">@item.PrecioVentaProducto.ToString("C")</p>

                                <a asp-controller="Productos"
                                   asp-action="Detalle"
                                   asp-route-id="@item.IdProducto"
                                   class="btn btn-outline-dark rounded-pill w-100">
                                    Ver detalle
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                }
        </div>
    }
</div>