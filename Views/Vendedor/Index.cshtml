@using ECOMMERCE_NEXOSOFT.Models

@{
    ViewData["Title"] = "Panel vendedor";
    var stockCritico = ViewBag.StockCritico as List<Stock> ?? new List<Stock>();
    var ultimosPedidos = ViewBag.UltimosPedidos as IEnumerable<ECOMMERCE_NEXOSOFT.Models.Pedido> ?? new List<ECOMMERCE_NEXOSOFT.Models.Pedido>();
}

@if (TempData["MensajeError"] != null)
{
    <div class="alert alert-danger">
        @TempData["MensajeError"]
    </div>
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Panel vendedor</h2>
        <p class="text-muted mb-0">Resumen operativo, comercial y de inventario de tu tienda.</p>
        <p class="mb-0 mt-2">
            <strong>Tienda:</strong> @ViewBag.NombreTienda
            @if ((bool)(ViewBag.TiendaVisiblePublico ?? false))
            {
                <span class="badge bg-success ms-2">Visible al público</span>
            }
            else
            {
                <span class="badge bg-secondary ms-2">Oculta al público</span>
            }
        </p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Productos</h6>
                    <h3 class="fw-bold">@(ViewBag.TotalProductos ?? 0)</h3>
                    <small class="text-muted">Publicados: @(ViewBag.ProductosPublicados ?? 0) | Ocultos: @(ViewBag.ProductosOcultos ?? 0)</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Pedidos</h6>
                    <h3 class="fw-bold">@(ViewBag.TotalPedidos ?? 0)</h3>
                    <small class="text-muted">Pendientes: @(ViewBag.PedidosPendientes ?? 0) | Entregados: @(ViewBag.PedidosEntregados ?? 0)</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Stock bajo</h6>
                    <h3 class="fw-bold text-warning">@(ViewBag.TotalStockBajo ?? 0)</h3>
                    <small class="text-muted">Productos por revisar</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Recaudo demo</h6>
                    <h3 class="fw-bold text-success">@(((decimal)(ViewBag.TotalRecaudado ?? 0m)).ToString("C"))</h3>
                    <small class="text-muted">Pagos aprobados de tu tienda</small>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Ventas registradas</h6>
                    <h3 class="fw-bold">@(ViewBag.TotalVentas ?? 0)</h3>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h6 class="text-muted">Pagos aprobados</h6>
                    <h3 class="fw-bold text-success">@(ViewBag.TotalPagosAprobados ?? 0)</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h4 class="fw-bold mb-3">Productos a revisar por inventario</h4>

                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Producto</th>
                                    <th>Stock actual</th>
                                    <th>Stock mínimo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (stockCritico == null || !stockCritico.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-center text-muted py-3">
                                            No hay productos para revisar.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var item in stockCritico)
                                    {
                                        <tr class="@(item.StockActual <= item.StockMinimo ? "table-warning" : "")">
                                            <td>@item.IdProductoNavigation?.NombreProducto</td>
                                            <td>@item.StockActual</td>
                                            <td>@item.StockMinimo</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <a asp-controller="Stock" asp-action="Index" class="btn btn-outline-dark">
                            Ver mi stock
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body">
                    <h4 class="fw-bold mb-3">Últimos pedidos de mi tienda</h4>

                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Código</th>
                                    <th>Fecha</th>
                                    <th>Total</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ultimosPedidos == null || !ultimosPedidos.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-3">
                                            No hay pedidos recientes para esta tienda.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var pedido in ultimosPedidos)
                                    {
                                        <tr>
                                            <td>@pedido.CodPedido</td>
                                            <td>@pedido.FechaCreacion.ToString("dd/MM/yyyy")</td>
                                            <td>@pedido.Total.ToString("C")</td>
                                            <td>
                                                @if (pedido.EstadoPedido == "pendiente")
                                                {
                                                    <span class="badge bg-warning text-dark">Pendiente</span>
                                                }
                                                else if (pedido.EstadoPedido == "en camino")
                                                {
                                                    <span class="badge bg-info text-dark">En camino</span>
                                                }
                                                else if (pedido.EstadoPedido == "entregado")
                                                {
                                                    <span class="badge bg-success">Entregado</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Cancelado</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <a asp-controller="VendedorPedidos" asp-action="Index" class="btn btn-outline-dark">
                            Ver pedidos de mi tienda
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Accesos rápidos</h5>

                <div class="d-flex flex-wrap gap-2">
                    <a asp-controller="MiTienda" asp-action="Index" class="btn btn-outline-dark">Mi perfil tienda</a>
                    <a asp-controller="Producto" asp-action="Index" class="btn btn-outline-dark">Mis productos</a>
                    <a asp-controller="Stock" asp-action="Index" class="btn btn-outline-dark">Mi stock</a>
                    <a asp-controller="VendedorPedidos" asp-action="Index" class="btn btn-outline-dark">Pedidos de mi tienda</a>
                    <a asp-controller="Vendedor" asp-action="Metricas" class="btn btn-outline-dark">Métricas de mi tienda</a>
                </div>
            </div>
        </div>
    </div>
</div>